# ─── Soloris — modèle de variables d'environnement ───────────────────
# Copier en .env et renseigner les valeurs.

SITE_URL=https://soloris.fr

# Supabase (valeurs publiques)
PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Supabase secret (serveur uniquement — ne jamais exposer)
SUPABASE_SERVICE_ROLE=service_role_key_xxx

# Tracking
PUBLIC_GTM_ID=GTM-XXXXXXX                 # Google Tag Manager (gère GA4 et autres tags)
PUBLIC_GA4_ID=G-XXXXXXXXXX                # facultatif si GA4 est dans GTM
PUBLIC_GADS_ID=AW-XXXXXXXXXX              # Google Ads
PUBLIC_GADS_CONVERSION_LABEL=xxxxxxxx     # conversion : soumission formulaire
PUBLIC_GADS_PHONE_LABEL=xxxxxxxx          # conversion : clic téléphone (action distincte)
PUBLIC_META_PIXEL_ID=000000000000000      # facultatif (pub Meta)
