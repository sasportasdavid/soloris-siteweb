---
/**
 * Formulaire de devis multi-étapes + estimation immédiate (grille ÂGE × SURFACE).
 * Étapes : projet → type de bien → surface (+ âge si vente/location) → adresse → coordonnées.
 * - Estimation « à partir de X € » (ou « sur devis » > 239 m²), jamais un prix ferme.
 * - Attribution utm/gclid/fbclid → champs cachés → leads.
 * - Conversions ads après consentement (Consent Mode v2).
 * - CRO : email facultatif, micro-réassurance, note 4,9★ en en-tête,
 *   capture anticipée du téléphone (lead « partiel » si abandon), A/B test du CTA.
 * Préselection via ?type=vente|location|dpe|audit.
 */
import {
  DEMANDE_LABELS, AGE_LABELS, AGE_DESC, SURFACE_BANDS, APPART_GRID,
  MAISON_SUPP, AUDIT_FROM, LOT_ANNEXE_PRICE, TYPE_BIEN_LABELS, FIXED, estimerDpe,
} from '../lib/pricing';
import { SITE } from '../lib/site';

/**
 * Props (toutes optionnelles). Défauts = comportement HISTORIQUE inchangé : les deux
 * tests A/B cookie (cta_devis, steps_order) tournent normalement, estimation affichée.
 * Sur les landing pages /lp/vente-* on passe lockExperiments=true (baseline forcée,
 * aucun cookie/impression cta_devis|steps_order) + priceModelVariant ('A'|'B') et
 * revealEstimation (A=true affiche le prix, B=false le calcule mais ne l'affiche pas).
 */
interface Props {
  lockExperiments?: boolean;
  forceCta?: 'A' | 'B';
  forceSteps?: 'A' | 'B';
  priceModelVariant?: 'A' | 'B' | null;
  revealEstimation?: boolean;
  recallSla?: string;
  /** Projet pré-sélectionné à l'étape 1 si l'URL ne porte pas ?type= (ex. landing DPE
   *  dédiée → 'dpe'). Défaut '' = comportement historique (rien de pré-coché). */
  defaultDemande?: string;
}
const {
  lockExperiments = false,
  forceCta = 'A',
  forceSteps = 'A',
  priceModelVariant = null,
  revealEstimation = true,
  recallSla = '48 h',
  defaultDemande = '',
} = Astro.props;

const DEMANDE_DESC: Record<string, string> = {
  vente: 'Je vends un bien',
  location: 'Je mets en location',
  dpe: 'Juste le diagnostic énergie',
  audit: 'Logement classé F, G ou E',
};

const hasReviews = Number(SITE.rating.count) > 0;
const surfaceBands = SURFACE_BANDS.map((b) => b.label);
// Prix DPE par bande de surface, dérivé d'estimerDpe() → source unique (pas de barème en dur).
const dpeByBand = SURFACE_BANDS.map((b) => estimerDpe(b.maxIncl === Infinity ? 240 : b.maxIncl));

// Conversion Google Ads « formulaire devis » — déclenchée DIRECTEMENT côté code au succès
// réel de l'enregistrement (même schéma que la conversion « appel » dans Analytics.astro),
// SANS dépendre d'un tag GTM (qui n'était pas configuré → 0 conversion remontée à Google).
// send_to = AW-XXXX/LABEL ; vide si non configuré → aucun envoi.
const _GADS_ID = import.meta.env.PUBLIC_GADS_ID;
const _GADS_FORM_LABEL = import.meta.env.PUBLIC_GADS_CONVERSION_LABEL;
const _GADS_PH = '__A_REMPLACER__';
const FORM_SEND_TO =
  _GADS_ID && _GADS_ID !== _GADS_PH && _GADS_FORM_LABEL && _GADS_FORM_LABEL !== _GADS_PH
    ? `${_GADS_ID}/${_GADS_FORM_LABEL}`
    : '';
// Conversion DÉDIÉE aux leads « DPE seul » (low-ticket) → action Google Ads « Soloris - Devis DPE »
// (id 7652003036). Séparée de la Vente pour que le Smart Bidding distingue le CA réel : un devis
// Vente vaut bien plus qu'un DPE seul. Label public (non secret) codé en dur comme la conversion
// « rappel » de CallbackForm ; seul l'ID Ads vient de l'env. Les leads vente/location/audit gardent
// FORM_SEND_TO (action « Soloris - Devis Vente », ex-« Devis (formulaire) », historique conservé).
const _GADS_DPE_LABEL = 'jvpdCNyZ4cAcEJXottlD';
const FORM_SEND_TO_DPE =
  _GADS_ID && _GADS_ID !== _GADS_PH ? `${_GADS_ID}/${_GADS_DPE_LABEL}` : '';
---
<div class="qform card" id="qform">
  {hasReviews && (
    <div class="qrating">
      <span class="stars" aria-hidden="true">
        {[0,1,2,3,4].map(() => <svg width="14" height="14" viewBox="0 0 24 24" fill="#F5A623"><path d="M12 2l2.9 6.2 6.8.8-5 4.7 1.3 6.7L12 17.8 5.9 20.4 7.2 13.7l-5-4.7 6.8-.8z"/></svg>)}
      </span>
      <strong>{SITE.rating.value}</strong> · {SITE.rating.count} avis Google
    </div>
  )}

  <form id="quote-form" novalidate>
    <div class="qsteps" aria-hidden="true">
      <span class="dot active" data-dot="1"></span><span class="dot" data-dot="2"></span>
      <span class="dot" data-dot="3"></span><span class="dot" data-dot="4"></span><span class="dot" data-dot="5"></span>
    </div>

    <!-- Étape 1 — Projet -->
    <fieldset class="qstep" data-step="1">
      <legend>Quel est votre projet&nbsp;?</legend>
      <p class="qsub">Choisissez votre situation : on calcule le bon tarif, tout compris.</p>
      <div class="qgrid">
        {Object.entries(DEMANDE_LABELS).map(([val, label]) => (
          <label class="qopt">
            <input type="radio" name="type_demande" value={val} required />
            <span class="qopt-body"><b>{label}</b><span class="qopt-desc">{DEMANDE_DESC[val]}</span></span>
          </label>
        ))}
      </div>
      <div class="qnav"><span></span><button type="button" class="btn-blue" data-next>Continuer</button></div>
    </fieldset>

    <!-- Étape 2 — Type de bien -->
    <fieldset class="qstep" data-step="2" hidden>
      <legend>Quel type de bien&nbsp;?</legend>
      <p class="qsub">Le tarif dépend du type de logement.</p>
      <div class="qgrid qgrid-2">
        <label class="qopt"><input type="radio" name="type_bien" value="appartement" required /><span class="qopt-body"><b>Appartement</b><span class="qopt-desc">En immeuble / copropriété</span></span></label>
        <label class="qopt"><input type="radio" name="type_bien" value="maison" required /><span class="qopt-body"><b>Maison</b><span class="qopt-desc">Individuelle</span></span></label>
      </div>

      <!-- Lots annexes vendus/loués seuls (cave/parking/box) — tarif unique. Affiché pour vente/location uniquement. -->
      <div id="lot-annexe-block" hidden>
        <span class="qgroup-label" style="display:block;margin:16px 0 9px">Ou un lot annexe seul</span>
        <div class="qgrid qgrid-2">
          <label class="qopt"><input type="radio" name="type_bien" value="cave" /><span class="qopt-body"><b>Cave</b><span class="qopt-desc">Lot de cave</span></span></label>
          <label class="qopt"><input type="radio" name="type_bien" value="parking" /><span class="qopt-body"><b>Parking</b><span class="qopt-desc">Place de stationnement</span></span></label>
          <label class="qopt"><input type="radio" name="type_bien" value="box" /><span class="qopt-body"><b>Box</b><span class="qopt-desc">Box fermé</span></span></label>
        </div>
      </div>

      <div class="qnav"><button type="button" class="btn-ghost" data-prev>Retour</button><button type="button" class="btn-blue" data-next>Continuer</button></div>
    </fieldset>

    <!-- Étape 3 — Surface + âge + estimation -->
    <fieldset class="qstep" data-step="3" hidden>
      <legend>Votre logement</legend>
      <p class="qsub" id="step3-sub">Indiquez la surface et l'âge du bien : les diagnostics obligatoires varient selon l'année de construction.</p>

      <label class="qfield">
        <span>Surface du bien (en m²)</span>
        <input type="number" name="surface_m2" inputmode="numeric" min="1" max="2000" step="1" placeholder="ex : 75" autocomplete="off" />
        <small class="qfield-help">Surface habitable approximative, en mètres carrés.</small>
      </label>

      <div id="age-block" class="qfield-group" hidden>
        <span class="qgroup-label">Âge du bien</span>
        <div class="qgrid qgrid-2">
          {Object.entries(AGE_LABELS).map(([val, label]) => (
            <label class="qopt"><input type="radio" name="age_bien" value={val} /><span class="qopt-body"><b>{label}</b><span class="qopt-desc">{AGE_DESC[val]}</span></span></label>
          ))}
        </div>
      </div>

      <label class="qcheck" id="copro-block" hidden>
        <input type="checkbox" name="copropriete" value="1" />
        <span>Maison en copropriété {revealEstimation && <span class="qopt-tag">+ {FIXED.coproSupp} €</span>}</span>
      </label>

      <label class="qcheck" id="annexe-appart-block" hidden>
        <input type="checkbox" name="annexe_appart" value="1" />
        <span>Cave, parking ou box à diagnostiquer {revealEstimation && <span class="qopt-tag qopt-tag-incl">inclus</span>}<span class="qcheck-help">Diagnostic d'un lot annexe (cave, parking, box) rattaché au bien — inclus dans le pack.</span></span>
      </label>
      <label class="qcheck" id="annexe-maison-block" hidden>
        <input type="checkbox" name="annexe_maison" value="1" />
        <span>Garage ou dépendance à diagnostiquer {revealEstimation && <span class="qopt-tag qopt-tag-incl">inclus</span>}<span class="qcheck-help">Pour une annexe séparée (garage non attenant, dépendance) — incluse dans le pack.</span></span>
      </label>

      <div class="qestim" id="estim" hidden>
        {revealEstimation ? (
          <>
            <div class="qestim-amount">🔒 Votre estimation est prête</div>
            <p class="qestim-note">Laissez vos coordonnées à l'étape suivante pour découvrir votre tarif tout compris — déplacement inclus, sans engagement.</p>
          </>
        ) : (
          <>
            <div class="qestim-amount">Obtenez votre devis personnalisé</div>
            <p class="qestim-note">Tarif tout compris confirmé lors de votre rappel sous {recallSla}. Sans engagement, déplacement inclus.</p>
          </>
        )}
      </div>

      <div class="qnav"><button type="button" class="btn-ghost" data-prev>Retour</button><button type="button" class="btn-blue" data-next>Continuer</button></div>
    </fieldset>

    <!-- Étape 4 — Code postal -->
    <fieldset class="qstep" data-step="4" hidden>
      <legend>Où se situe le bien&nbsp;?</legend>
      <p class="qsub">Indiquez le code postal du logement.</p>
      <label class="qfield">
        <span>Code postal</span>
        <input type="text" name="secteur" id="cp-input" required inputmode="numeric" maxlength="5" pattern="\d{5}" placeholder="ex : 75011" autocomplete="postal-code" />
      </label>
      <label class="qfield" id="ville-field" hidden>
        <span>Ville</span>
        <select name="ville" id="ville-select" autocomplete="address-level2"></select>
      </label>
      <p class="qhint">Nous intervenons à Paris et en Île-de-France (codes postaux 75, 77, 78, 91, 92, 93, 94, 95).</p>
      <div class="qnav"><button type="button" class="btn-ghost" data-prev>Retour</button><button type="button" class="btn-blue" data-next>Continuer</button></div>
    </fieldset>

    <!-- Étape 5 — Coordonnées -->
    <fieldset class="qstep" data-step="5" hidden>
      <legend>Vos coordonnées</legend>
      <div class="qrecap" id="qrecap" hidden></div>
      <label class="qfield"><span>Nom et prénom</span><input type="text" name="nom" required autocomplete="name" placeholder="Camille Roussel" /></label>
      <label class="qfield"><span>Téléphone</span><input type="tel" name="telephone" required autocomplete="tel" placeholder="06 12 34 56 78" /></label>
      <label class="qfield"><span>Email</span><input type="email" name="email" required autocomplete="email" placeholder="vous@email.fr" /><small class="qfield-help">Pour recevoir votre devis et votre confirmation par email.</small></label>
      <label class="qfield"><span>Message (optionnel)</span><textarea name="message" rows="2" placeholder="Une précision sur votre bien ?"></textarea></label>

      <div class="qhp" aria-hidden="true"><label>Ne pas remplir<input type="text" name="website" tabindex="-1" autocomplete="off" /></label></div>

      <input type="hidden" name="surface" /><input type="hidden" name="estimation" />

      <p class="qprivacy">Vos informations sont enregistrées pour vous recontacter au sujet de votre demande.</p>

      <div class="qreassure">
        <span>🔒 Sans engagement</span><span>· Vos données restent confidentielles</span><span>· Réponse sous 48 h</span>
      </div>
      <p class="qconsent">En envoyant ce formulaire, vous acceptez d'être recontacté par Soloris au sujet de votre demande. Vos données sont traitées conformément à notre <a href="/confidentialite">politique de confidentialité</a>.</p>

      <div class="qnav">
        <button type="button" class="btn-ghost" data-prev>Retour</button>
        <button type="submit" class="btn-gold" id="qsubmit">Obtenir mon devis</button>
      </div>
    </fieldset>
  </form>

  <div class="qthanks" id="qthanks" hidden>
    <div class="qthanks-ic" aria-hidden="true"><svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="#0B2A4A" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></div>
    <h3>Merci, c'est noté&nbsp;!</h3>
    <p>Votre demande est bien enregistrée. Un diagnostiqueur Soloris vous recontacte très vite pour confirmer votre devis et fixer un rendez-vous sous 48&nbsp;h.</p>
    <div class="qthanks-estim" id="qthanks-estim" hidden></div>
    <a href="/" class="btn-blue mt-3">Retour à l'accueil</a>
  </div>
</div>

<style>
  .qform { padding: 24px 30px 28px; max-width: 600px; margin: 0 auto; }
  .qrating { display: flex; align-items: center; gap: 8px; justify-content: center; font-family: var(--sora); font-size: 13px; color: var(--ink-soft); padding-bottom: 16px; margin-bottom: 6px; border-bottom: 1px solid var(--line); }
  .qrating .stars { display: inline-flex; gap: 1px; }
  .qrating strong { color: var(--blue); }
  .qsteps { display: flex; gap: 8px; justify-content: center; margin: 8px 0 26px; }
  .qsteps .dot { width: 30px; height: 5px; border-radius: 4px; background: var(--line); transition: background .2s; }
  .qsteps .dot.active { background: var(--gold); }
  .qstep { border: none; }
  .qstep legend { font-family: var(--sora); font-weight: 600; font-size: 22px; color: var(--blue); margin-bottom: 6px; padding: 0; letter-spacing: -.01em; }
  .qsub { font-size: 14px; color: var(--ink-soft); margin-bottom: 18px; }
  .qgrid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  @media (max-width: 480px) { .qgrid { grid-template-columns: 1fr; } }
  .qopt { position: relative; cursor: pointer; }
  .qopt input { position: absolute; opacity: 0; inset: 0; cursor: pointer; }
  .qopt-body { display: block; border: 1.5px solid var(--line); border-radius: 12px; padding: 16px 18px; transition: border-color .15s, background .15s; }
  .qopt-body b { font-family: var(--sora); font-weight: 600; color: var(--blue); font-size: 15px; }
  .qopt-desc { display: block; font-family: var(--inter); font-weight: 400; font-size: 12.5px; color: var(--ink-soft); margin-top: 3px; }
  .qopt:hover .qopt-body { border-color: var(--blue-light); }
  .qopt input:checked + .qopt-body { border-color: var(--gold); background: rgba(245,166,35,.07); }
  .qopt input:focus-visible + .qopt-body { outline: 3px solid var(--blue-light); outline-offset: 2px; }
  .qopt-tag { font-family: var(--inter); font-weight: 400; font-size: 12px; color: var(--ink-soft); }
  .qopt-tag-incl { font-weight: 600; color: #1a7f4b; text-transform: uppercase; letter-spacing: .03em; font-size: 11px; }
  .qfield { display: block; margin-top: 16px; }
  .qfield:first-of-type { margin-top: 0; }
  .qfield span { display: block; font-family: var(--sora); font-size: 13px; font-weight: 500; color: var(--ink); margin-bottom: 7px; }
  .qfield input, .qfield textarea, .qfield select { width: 100%; border: 1.5px solid var(--line); border-radius: 10px; padding: 12px 14px; font-family: var(--inter); font-size: 15px; color: var(--ink); background: #fff; }
  .qfield input:focus, .qfield textarea:focus, .qfield select:focus { outline: none; border-color: var(--blue-light); }
  .qfield-help { display: block; font-family: var(--inter); font-weight: 400; font-size: 12px; color: var(--ink-soft); margin-top: 6px; line-height: 1.45; }
  .qfield-group { margin-top: 18px; }
  .qgroup-label { display: block; font-family: var(--sora); font-size: 13px; font-weight: 500; color: var(--ink); margin-bottom: 9px; }
  .qcheck { display: flex; align-items: center; gap: 10px; margin-top: 16px; font-family: var(--inter); font-size: 14px; color: var(--ink); cursor: pointer; }
  .qcheck input { width: 18px; height: 18px; accent-color: var(--blue-light); flex: none; align-self: start; margin-top: 2px; }
  .qcheck-help { display: block; font-size: 12px; color: var(--ink-soft); margin-top: 3px; line-height: 1.45; }
  .qcheck { align-items: flex-start; }
  .qrecap { background: var(--paper); border: 1px solid var(--line); border-left: 3px solid var(--gold); border-radius: 12px; padding: 14px 16px; margin-bottom: 20px; font-size: 13.5px; color: var(--ink-soft); }
  .qrecap b { color: var(--blue); }
  .qrecap .qrecap-price { font-family: var(--sora); font-weight: 600; color: var(--blue); }
  .qhint { margin-top: 14px; font-size: 14px; color: var(--blue-light); background: rgba(46,111,174,.08); padding: 12px 14px; border-radius: 10px; }
  .qac { position: relative; }
  .qac-list { position: absolute; z-index: 5; left: 0; right: 0; top: 100%; margin-top: 6px; background: #fff; border: 1px solid var(--line); border-radius: 12px; box-shadow: var(--shadow-soft); max-height: 252px; overflow-y: auto; list-style: none; padding: 5px; }
  .qac-list li { padding: 10px 12px; border-radius: 8px; cursor: pointer; font-size: 14px; color: var(--ink); line-height: 1.35; display: flex; align-items: center; gap: 10px; }
  .qac-list li svg { flex: none; color: var(--blue-light); }
  .qac-list li:hover, .qac-list li[aria-selected="true"] { background: var(--paper); }
  .qac-list li b { font-weight: 500; }
  .qac-list li .ac-ctx { color: var(--ink-soft); font-size: 12.5px; }
  .qestim { margin-top: 20px; border: 1px solid var(--line); border-left: 3px solid var(--gold); border-radius: 12px; padding: 18px 20px; background: var(--paper); }
  .qestim-amount { font-family: var(--sora); font-size: 16px; color: var(--ink-soft); }
  .qestim-amount strong { font-size: 30px; font-weight: 600; color: var(--blue); }
  .qestim-note { font-size: 12.5px; color: var(--ink-soft); margin-top: 6px; line-height: 1.5; }
  .qnav { display: flex; justify-content: space-between; gap: 12px; margin-top: 26px; }
  .qnav .btn-blue, .qnav .btn-gold { margin-left: auto; }
  .qreassure { display: flex; flex-wrap: wrap; gap: 4px 6px; margin-top: 18px; font-family: var(--sora); font-size: 12px; font-weight: 500; color: var(--blue-light); }
  .qprivacy { font-size: 11.5px; color: var(--ink-soft); margin-top: 14px; line-height: 1.5; font-style: italic; }
  .qconsent { font-size: 12px; color: var(--ink-soft); margin-top: 10px; line-height: 1.55; }
  .qconsent a { color: var(--blue-light); text-decoration: underline; }
  .qhp { position: absolute; left: -9999px; height: 0; overflow: hidden; }
  .qerror { color: #b3261e; font-size: 13px; margin-top: 12px; }
  .qthanks { text-align: center; padding: 20px 10px; }
  .qthanks-ic { width: 64px; height: 64px; border-radius: 50%; background: rgba(245,166,35,.16); display: flex; align-items: center; justify-content: center; margin: 0 auto 18px; }
  .qthanks h3 { font-family: var(--sora); font-weight: 600; font-size: 24px; color: var(--blue); }
  .qthanks p { color: var(--ink-soft); margin-top: 12px; max-width: 420px; margin-left: auto; margin-right: auto; line-height: 1.6; }
  .qthanks-estim { margin: 18px auto 4px; max-width: 440px; background: var(--paper); border: 1px solid var(--line); border-left: 3px solid var(--gold); border-radius: 12px; padding: 14px 16px; font-size: 14px; color: var(--ink-soft); line-height: 1.55; }
  .qthanks-estim strong { font-family: var(--sora); font-size: 19px; color: var(--blue); }
</style>

<script is:inline define:vars={{ APPART_GRID, MAISON_SUPP, AUDIT_FROM, COPRO_SUPP: FIXED.coproSupp, DPE_BY_BAND: dpeByBand, LOT_ANNEXE_PRICE, BIEN_LABELS: TYPE_BIEN_LABELS, BANDS_MAX: SURFACE_BANDS.map((b) => (b.maxIncl === Infinity ? 240 : b.maxIncl)), SURF_LABELS: surfaceBands, DEMANDE_LABELS, AGE_LABELS, LOCK_EXPERIMENTS: lockExperiments, FORCE_CTA: forceCta, FORCE_STEPS: forceSteps, PRICE_MODEL: priceModelVariant, REVEAL_ESTIMATION: revealEstimation, DEFAULT_DEMANDE: defaultDemande, FORM_SEND_TO, FORM_SEND_TO_DPE }}>
  (function () {
    var form = document.getElementById('quote-form');
    if (!form) return;
    var steps = Array.prototype.slice.call(form.querySelectorAll('.qstep'));
    var dots = Array.prototype.slice.call(form.querySelectorAll('.dot'));
    var current = 0;
    var submitted = false;
    var leadEventSent = false; // garde anti-double-envoi de l'event de conversion (Tâche 4)
    var reachedEstimation = false;
    var maxReached = 0;
    var abStepsB = false; // variante B du test A/B (type de bien fusionné à l'étape surface)
    var AGE_IDX = { avant1949: 0, intermediaire: 1, recent: 2 };

    // Option annexe (supplément) : visible pour un pack (vente/location). Cave/parking pour
    // un appartement, garage/dépendance pour une maison. Mutuellement exclusif selon le bien.
    function annexeState() {
      var d = demande(), b = bien();
      var isPack = (d === 'vente' || d === 'location');
      if (!isPack) return { on: false, type: '' };
      if (b === 'appartement') { var c = form.querySelector('[name="annexe_appart"]'); return { on: !!(c && c.checked), type: 'cave_parking' }; }
      if (b === 'maison') { var c2 = form.querySelector('[name="annexe_maison"]'); return { on: !!(c2 && c2.checked), type: 'garage_dependance' }; }
      return { on: false, type: '' };
    }

    function fmtEUR(n) { return new Intl.NumberFormat('fr-FR', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 }).format(n); }
    function val(name) { var el = form.querySelector('[name="' + name + '"]'); return el ? el.value : ''; }
    function checkedVal(name) { var el = form.querySelector('input[name="' + name + '"]:checked'); return el ? el.value : null; }
    function demande() { return checkedVal('type_demande'); }
    function bien() { return checkedVal('type_bien'); }
    function isLotBien() { var b = bien(); return b === 'cave' || b === 'parking' || b === 'box'; }
    function ageNeeded() { var d = demande(); return d === 'vente' || d === 'location'; }
    // Surface saisie en m² (champ numérique). Renvoie null si vide/invalide.
    function surfaceM2() { var el = form.querySelector('[name="surface_m2"]'); var v = el ? parseInt(el.value, 10) : NaN; return (isNaN(v) || v <= 0) ? null : v; }
    // Index de la bande tarifaire correspondant à la surface en m² (grille pricing.ts).
    function bandIndex() { var m2 = surfaceM2(); if (m2 == null) return null; for (var i = 0; i < BANDS_MAX.length; i++) { if (m2 <= BANDS_MAX[i]) return i; } return BANDS_MAX.length - 1; }

    // Étape « à choix unique » : UN seul groupe de radios, et AUCUN autre champ à
    // remplir (select, texte, nombre, case à cocher…). Sinon on garde « Continuer ».
    function isAutoStep(step) {
      if (!step) return false;
      if (step.querySelector('select, textarea, input:not([type="radio"]):not([type="hidden"])')) return false;
      var radios = step.querySelectorAll('input[type="radio"]');
      if (!radios.length) return false;
      var names = {}; radios.forEach(function (r) { names[r.name] = 1; });
      return Object.keys(names).length === 1;
    }
    // Sur ces étapes, on masque « Continuer » (l'avance est automatique au choix)
    function applyAutoSteps() {
      steps.forEach(function (step) {
        if (!isAutoStep(step)) return;
        var next = step.querySelector('[data-next]'); if (next) next.style.display = 'none';
        var prev = step.querySelector('[data-prev]'); var nav = step.querySelector('.qnav');
        if (nav && !prev) nav.style.display = 'none';
      });
    }

    function showStep(i, userAction) {
      steps.forEach(function (s, idx) { s.hidden = idx !== i; });
      dots.forEach(function (d, idx) { d.classList.toggle('active', idx <= i); });
      current = i;
      updateEstimation(); // rafraîchit estimation + visibilité âge/copropriété/annexe
      if (i === steps.length - 1) buildRecap(); // récap avant l'envoi (CRO #5)
      if (i > maxReached) { maxReached = i; if (i >= 1) upsertLead('partiel'); } // capture progressive
      // ⚠️ Aucun scroll ni focus à l'initialisation (étape 0 au chargement) : sinon la page
      // saute vers le formulaire et masque le hero/les prix. Uniquement sur action utilisateur.
      if (userAction) {
        var f = steps[i].querySelector('input, select, textarea, button');
        if (f) { try { f.focus({ preventScroll: true }); } catch (e) { f.focus(); } }
        document.getElementById('qform').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    }

    function validStep(i) {
      var step = steps[i];
      var ok = true;
      // radios requis
      var radioNames = {};
      step.querySelectorAll('input[type="radio"][required]').forEach(function (el) { radioNames[el.name] = true; });
      Object.keys(radioNames).forEach(function (n) { if (!form.querySelector('input[name="' + n + '"]:checked')) ok = false; });
      // champs texte/select requis
      step.querySelectorAll('input[required]:not([type="radio"]), select[required], textarea[required]').forEach(function (el) {
        if (!el.value.trim()) { ok = false; el.style.borderColor = '#b3261e'; } else { el.style.borderColor = ''; }
        if (el.type === 'email' && el.value && !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(el.value)) { ok = false; el.style.borderColor = '#b3261e'; }
      });
      // étape 3 : logement → surface obligatoire (+ âge pour vente/location) ;
      //           lot annexe (cave/parking/box) → surface facultative, pas d'âge.
      if (step.getAttribute('data-step') === '3' && !isLotBien()) {
        var sb = form.querySelector('[name="surface_m2"]');
        if (surfaceM2() == null) { ok = false; if (sb) sb.style.borderColor = '#b3261e'; } else if (sb) { sb.style.borderColor = ''; }
        if (ageNeeded() && !checkedVal('age_bien')) ok = false;
      }
      // étape 4 : code postal valide (5 chiffres, Île-de-France)
      if (step.getAttribute('data-step') === '4') {
        var cp = (val('secteur') || '').trim();
        var IDF = ['75', '77', '78', '91', '92', '93', '94', '95'];
        if (!/^\d{5}$/.test(cp) || IDF.indexOf(cp.slice(0, 2)) === -1) {
          ok = false;
          var cpEl = form.querySelector('#cp-input'); if (cpEl) cpEl.style.borderColor = '#b3261e';
        }
      }
      return ok;
    }

    // Récap de la demande à la dernière étape (CRO #5)
    function buildRecap() {
      var el = document.getElementById('qrecap'); if (!el) return;
      var d = demande(), b = bien(), m2 = surfaceM2(), age = checkedVal('age_bien'), est = val('estimation');
      var parts = [];
      if (d && DEMANDE_LABELS[d]) parts.push(DEMANDE_LABELS[d]);
      if (b) parts.push(BIEN_LABELS[b] || b);
      if (m2 != null) parts.push(m2 + ' m²');
      if (age && AGE_LABELS[age]) parts.push(AGE_LABELS[age]);
      var ax = annexeState();
      var annexeLabel = ax.type === 'garage_dependance' ? ' + garage/dépendance' : ' + cave/parking';
      // Le montant de l'annexe n'est affiché QUE si l'estimation est révélée (pas en LP-B).
      var annexeTxt = ax.on ? (REVEAL_ESTIMATION ? annexeLabel + ' (inclus)' : annexeLabel) : '';
      // Estimation conditionnée au contact : on ne dévoile PAS le montant dans le récap
      // (il s'affiche sur l'écran de confirmation, une fois les coordonnées envoyées).
      var price = REVEAL_ESTIMATION ? ' — <span class="qrecap-price">🔒 dévoilée à l\'envoi</span>' : '';
      el.innerHTML = '<b>Votre demande :</b> ' + parts.join(' · ') + annexeTxt + price;
      el.hidden = parts.length === 0;
    }

    function updateEstimation() {
      var box = document.getElementById('estim');
      var amount = document.getElementById('estim-amount');
      var hEst = form.querySelector('[name="estimation"]');
      var hSurf = form.querySelector('[name="surface"]');
      var ageBlock = document.getElementById('age-block');
      var coproBlock = document.getElementById('copro-block');
      var annexeAppartBlock = document.getElementById('annexe-appart-block');
      var annexeMaisonBlock = document.getElementById('annexe-maison-block');
      var d = demande(), b = bien(), bi = bandIndex(), age = checkedVal('age_bien');
      var isPack = (d === 'vente' || d === 'location');
      var lot = isLotBien();

      // Lots annexes (cave/parking/box) : proposés pour vente/location uniquement.
      var lotBlock = document.getElementById('lot-annexe-block');
      if (lotBlock) lotBlock.hidden = !isPack;
      // Si on quitte vente/location avec un lot sélectionné, il devient invalide → on le désélectionne.
      if (lot && !isPack) {
        var selLot = form.querySelector('input[name="type_bien"]:checked');
        if (selLot) selLot.checked = false;
        b = null; lot = false;
      }

      if (ageBlock) ageBlock.hidden = !ageNeeded() || lot; // pas d'âge pour un lot annexe
      if (coproBlock) coproBlock.hidden = !(b === 'maison' && isPack); // copropriété : maison + pack
      if (annexeAppartBlock) annexeAppartBlock.hidden = !(b === 'appartement' && isPack);
      if (annexeMaisonBlock) annexeMaisonBlock.hidden = !(b === 'maison' && isPack);
      if (hSurf) { var sM2 = surfaceM2(); hSurf.value = sM2 != null ? String(sM2) : ''; } // surface réelle (m²)

      // Sous-titre conditionnel : lot annexe / DPE-audit / vente-location
      var sub = document.getElementById('step3-sub');
      if (sub) {
        if (lot) sub.textContent = 'La surface est facultative pour ce type de lot. Le tarif est unique, tout compris.';
        else if (ageNeeded()) sub.textContent = abStepsB
          ? 'Type de bien, surface et âge — on calcule votre estimation.'
          : "Indiquez la surface et l'âge du bien : les diagnostics obligatoires varient selon l'année de construction.";
        else sub.textContent = abStepsB
          ? 'Type de bien et surface — on calcule votre estimation.'
          : 'Indiquez la surface du bien pour votre estimation.';
      }

      var value = null, surDevis = false;
      if (lot) { value = LOT_ANNEXE_PRICE; } // cave / parking / box — tarif unique
      else if (d === 'audit') { value = AUDIT_FROM; }
      else if (d === 'dpe') { if (bi == null) { box.hidden = true; return; } value = DPE_BY_BAND[bi]; }
      else { // vente / location
        if (bi == null || (ageNeeded() && !age)) { box.hidden = true; return; }
        var row = APPART_GRID[bi];
        if (!row) { surDevis = true; }
        else {
          value = row[AGE_IDX[age]];
          if (b === 'maison') {
            value += MAISON_SUPP;
            if (form.querySelector('[name="copropriete"]:checked')) value += COPRO_SUPP;
          }
          // Annexe RATTACHÉE au logement (cave/parking/box d'un appartement, garage/dépendance
          // d'une maison) : INCLUSE dans le pack → aucun supplément. Seul le lot vendu SEUL
          // (type de bien = cave/parking/box) garde son tarif unique LOT_ANNEXE_PRICE (autre parcours).
        }
      }
      // RÈGLE NON NÉGOCIABLE : on calcule TOUJOURS prix_estime (champ caché hEst),
      // même en LP-B. Seul l'AFFICHAGE du montant est conditionné par REVEAL_ESTIMATION.
      if (surDevis) { if (hEst) hEst.value = ''; }
      else { if (hEst) hEst.value = String(value); }
      if (REVEAL_ESTIMATION && amount) { amount.textContent = surDevis ? 'sur devis' : fmtEUR(value); }
      box.hidden = false; // affiche la boîte : montant (A) ou microcopy « devis personnalisé » (B)
      reachedEstimation = true;
    }

    // Auto-avance sur une étape à choix unique. Déclenchée par `change` (clavier /
    // changement de valeur) ET par `click` (re-clic sur un choix DÉJÀ sélectionné,
    // qui n'émet pas de `change`). Le garde-fou `current === idx` empêche la double-avance.
    function maybeAutoAdvance(targetEl) {
      var stepEl = steps[current];
      if (!isAutoStep(stepEl) || !stepEl.contains(targetEl)) return;
      var idx = current;
      setTimeout(function () { if (current === idx && validStep(idx) && idx < steps.length - 1) showStep(idx + 1, true); }, 280);
    }

    form.addEventListener('change', function (e) {
      if (['type_demande', 'type_bien', 'surface_m2', 'age_bien', 'copropriete', 'annexe_appart', 'annexe_maison'].indexOf(e.target.name) > -1) {
        updateEstimation();
      }
      if (e.target.type === 'radio') maybeAutoAdvance(e.target);
    });
    // Estimation en direct pendant la saisie de la surface (sans attendre le blur).
    form.addEventListener('input', function (e) {
      if (e.target.name === 'surface_m2') { e.target.style.borderColor = ''; updateEstimation(); }
    });

    form.addEventListener('click', function (e) {
      if (e.target.matches('[data-next]')) {
        if (!validStep(current)) return;
        if (current < steps.length - 1) showStep(current + 1, true);
      } else if (e.target.matches('[data-prev]')) {
        if (current > 0) showStep(current - 1, true);
      } else if (e.target.matches('input[type="radio"]')) {
        // re-clic sur un radio déjà coché : `change` ne se déclenche pas → on avance ici
        if (e.target.checked) maybeAutoAdvance(e.target);
      }
    });

    // ── Identifiant de session (capture progressive) + acquisition ──
    function uuid() {
      try { if (window.crypto && crypto.randomUUID) return crypto.randomUUID(); } catch (e) {}
      return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function (c) { var r = Math.random() * 16 | 0; return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16); });
    }
    // Le lead_uid identifie UN parcours de devis (session), PAS un visiteur. Il est stocké
    // en sessionStorage (et non plus dans un cookie persistant 30 j) : un visiteur qui revient
    // repart donc sur un lead NEUF. Sinon sa nouvelle soumission réutilisait l'ancien lead_uid
    // → upsert_lead faisait un UPDATE de sa vieille ligne au lieu d'un INSERT (bug : 0 nouveau lead).
    function purgeLegacyLeadCookie() {
      try { document.cookie = 'soloris_lead_id=; expires=Thu, 01 Jan 1970 00:00:00 GMT; path=/; SameSite=Lax'; } catch (e) {}
    }
    function getLeadUid() {
      purgeLegacyLeadCookie(); // nettoie l'ancien cookie persistant (cause du bug)
      var v = '';
      try { v = sessionStorage.getItem('soloris_lead_uid') || ''; } catch (e) {}
      if (!/^[0-9a-f-]{36}$/i.test(v)) { v = uuid(); try { sessionStorage.setItem('soloris_lead_uid', v); } catch (e) {} }
      return v;
    }
    // Après un lead COMPLET confirmé : on retire le lead_uid pour qu'une soumission ultérieure
    // (même navigateur/onglet) reparte sur une nouvelle ligne. Le lien partiel→complet ne vaut
    // que DANS le parcours en cours.
    function clearLeadUid() {
      try { sessionStorage.removeItem('soloris_lead_uid'); } catch (e) {}
      purgeLegacyLeadCookie();
    }
    function getAcq() {
      try { var raw = (document.cookie.split('; ').find(function (c) { return c.indexOf('soloris_acq=') === 0; }) || '').split('=')[1]; return raw ? JSON.parse(decodeURIComponent(raw)) : {}; } catch (e) { return {}; }
    }
    function readCookie(name) {
      return (document.cookie.split('; ').find(function (c) { return c.indexOf(name + '=') === 0; }) || '').split('=')[1] || '';
    }
    function buildPayload(status) {
      var a = getAcq();
      var ax = annexeState();
      return {
        lead_uid: getLeadUid(), lead_status: status, source: 'devis',
        // Variante du test A/B « price_model » (landing pages vente) — '' hors LP.
        price_model: (PRICE_MODEL === 'A' || PRICE_MODEL === 'B') ? PRICE_MODEL : '',
        // Lien lead ↔ comportement (cookies posés par le tracker si consentement « Analyse de navigation »)
        session_id: readCookie('soloris_sid'), visitor_id: readCookie('soloris_vid'),
        type_demande: demande() || '', type_bien: bien() || '', age_bien: checkedVal('age_bien') || '',
        surface: val('surface'), estimation: val('estimation'), secteur: val('secteur'), ville: val('ville'),
        annexe: ax.on ? '1' : '0', annexe_type: ax.on ? ax.type : '',
        nom: val('nom'), telephone: val('telephone'), email: val('email'), message: val('message'),
        utm_source: a.utm_source || '', medium: a.utm_medium || '', campaign: a.utm_campaign || '',
        term: a.utm_term || '', content: a.utm_content || '', gclid: a.gclid || '', fbclid: a.fbclid || '',
        gads_keyword: a.keyword || '', gads_campaign_id: a.campaignid || '', gads_adgroup_id: a.adgroupid || '',
        gads_creative_id: a.creative || '', match_type: a.matchtype || '', device: a.device || '', network: a.network || '',
        landing_path: a.landing_path || window.location.pathname, referrer: a.referrer || '',
      };
    }
    // Upsert progressif (statut partiel) — fire & forget, AUCUNE conversion
    function upsertLead(status) {
      var p = buildPayload(status);
      if (!p.type_demande) return; // rien tant que le projet n'est pas choisi
      fetch('/api/lead', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(p) }).catch(function () {});
    }
    // Capture progressive : à chaque nouvelle étape atteinte + au blur tel/email
    ['telephone', 'email'].forEach(function (n) {
      var el = form.querySelector('[name="' + n + '"]');
      if (el) el.addEventListener('blur', function () { if (val('telephone') || val('email')) upsertLead('partiel'); });
    });

    (function preselect() {
      var t = new URLSearchParams(window.location.search).get('type') || DEFAULT_DEMANDE;
      if (!t) return;
      var radio = form.querySelector('input[name="type_demande"][value="' + t + '"]');
      if (radio) radio.checked = true;
    })();

    // ── Code postal : chiffres uniquement + auto-complétion ville + auto-avance ──
    (function setupCodePostal() {
      var input = form.querySelector('#cp-input');
      if (!input) return;
      var IDF = ['75', '77', '78', '91', '92', '93', '94', '95'];
      var villeSel = form.querySelector('#ville-select');
      var villeField = form.querySelector('#ville-field');
      var timer, reqId = 0;
      function validCp(v) { return /^\d{5}$/.test(v) && IDF.indexOf(v.slice(0, 2)) > -1; }
      function advance(idx) { timer = setTimeout(function () { if (current === idx && idx < steps.length - 1) showStep(idx + 1, true); }, 700); }
      input.addEventListener('input', function () {
        input.value = input.value.replace(/\D/g, '').slice(0, 5); // chiffres uniquement
        input.style.borderColor = '';
        clearTimeout(timer);
        if (villeField) villeField.hidden = true;
        if (villeSel) villeSel.innerHTML = '';
        if (!validCp(input.value)) return;
        var idx = current, cp = input.value, myReq = ++reqId;
        // Commune(s) du code postal (API officielle geo.api.gouv.fr, sans clé). Auto-avance
        // vers les coordonnées si une seule ville (rien à choisir) ; sinon on laisse choisir.
        fetch('https://geo.api.gouv.fr/communes?codePostal=' + cp + '&fields=nom&format=json')
          .then(function (r) { return r.ok ? r.json() : []; })
          .then(function (list) {
            if (myReq !== reqId) return; // le CP a changé entre-temps
            if (Array.isArray(list) && list.length && villeSel) {
              list.forEach(function (c) { var o = document.createElement('option'); o.value = c.nom; o.textContent = c.nom; villeSel.appendChild(o); });
              villeSel.selectedIndex = 0;
              if (villeField) villeField.hidden = false;
            }
            if (!Array.isArray(list) || list.length <= 1) advance(idx); // 0 ou 1 ville → on avance
          })
          .catch(function () { if (myReq === reqId) advance(idx); }); // API indisponible → comportement historique
      });
    })();

    // ── A/B test du CTA (variante stockée en cookie strictement nécessaire) ──
    // Sur les LP (LOCK_EXPERIMENTS) : baseline forcée FORCE_CTA, AUCUN cookie lu/posé,
    // AUCUNE impression 'cta_devis' (test isolé du test 'price_model').
    (function abCta() {
      var v;
      if (LOCK_EXPERIMENTS) {
        v = (FORCE_CTA === 'B') ? 'B' : 'A';
      } else {
        var name = 'soloris_ab_cta';
        v = (document.cookie.split('; ').find(function (c) { return c.indexOf(name + '=') === 0; }) || '').split('=')[1];
        if (v !== 'A' && v !== 'B') {
          v = Math.random() < 0.5 ? 'A' : 'B';
          var d = new Date(); d.setTime(d.getTime() + 90 * 864e5);
          document.cookie = name + '=' + v + '; expires=' + d.toUTCString() + '; path=/; SameSite=Lax';
        }
        try { if (window.dataLayer) window.dataLayer.push({ event: 'experiment_impression', experiment: 'cta_devis', variant: v }); } catch (e) {}
      }
      var btn = document.getElementById('qsubmit');
      if (btn && v === 'B') btn.textContent = 'Recevoir mon estimation gratuite';
    })();

    // ── Test 'price_model' (landing pages vente, réparti par URL via l'expérience Ads) ──
    // Émis UNIQUEMENT quand priceModelVariant ∈ {A,B} (donc jamais hors LP). Aucun cookie.
    (function priceModelImpression() {
      if (PRICE_MODEL !== 'A' && PRICE_MODEL !== 'B') return;
      try { if (window.dataLayer) window.dataLayer.push({ event: 'experiment_impression', experiment: 'price_model', variant: PRICE_MODEL }); } catch (e) {}
    })();

    // ── Capture anticipée : lead « partiel » si abandon après l'estimation ──
    function sendPartial() {
      if (submitted || !reachedEstimation) return;
      if (!(val('telephone') || val('email'))) return; // uniquement si un contact a été saisi
      try {
        var p = buildPayload('partiel');
        navigator.sendBeacon('/api/lead', new Blob([JSON.stringify(p)], { type: 'application/json' }));
      } catch (e) {} // upsert idempotent (même lead_uid) — ne bloque pas une soumission ultérieure
    }
    document.addEventListener('visibilitychange', function () { if (document.visibilityState === 'hidden') sendPartial(); });
    window.addEventListener('pagehide', sendPartial);

    // ── Soumission complète ──
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      if (!validStep(current)) return;
      var btn = document.getElementById('qsubmit'); btn.disabled = true; btn.textContent = 'Envoi…';
      submitted = true; // n'envoie plus de partiel

      // Lead COMPLET : upsert (statut complet) + conversion (uniquement ici)
      var payload = buildPayload('complet');

      fetch('/api/lead', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) })
        .then(function (r) { return r.json().then(function (j) { return { ok: r.ok, j: j }; }); })
        .then(function (res) {
          var lead = res.j || {};
          // ⚠️ On ne montre « Merci » QUE si l'écriture est confirmée : réponse OK + id présent
          // + (si l'API le renvoie) lead_status='complet'. Sinon → erreur, pas de page de succès.
          if (!res.ok || !lead.id || (lead.lead_status && lead.lead_status !== 'complet')) {
            throw new Error(lead.error ? lead.error : 'Erreur');
          }
          // Lead complet confirmé : on retire le lead_uid → la prochaine soumission repart à neuf.
          clearLeadUid();
          try {
            var v3 = Number(payload.estimation || 0);
            // ── Event de conversion CANONIQUE (Tâche 4) ─────────────────────────────
            // Poussé UNE seule fois, au succès RÉEL de l'enregistrement Supabase.
            // À mapper côté GTM (déclencheur « lead_submitted ») — la déduplication des
            // actions de conversion se règle dans Google Ads + GTM, PAS dans le code.
            // Consent Mode v2 : on se contente de pousser l'event ; GTM, en respectant
            // le consentement, décide de déclencher (ou non) le tag. Params disponibles :
            //   lead_id     → identifiant Supabase = transaction_id (dédup, OBLIGATOIRE)
            //   projet      → vente | location | dpe | audit
            //   prix_estime → number (value pour le Smart Bidding)
            //   currency    → 'EUR'
            if (!leadEventSent) {
              leadEventSent = true;
              var leadId = (res.j && res.j.id) ? res.j.id : (payload.lead_uid || null);
              // Event analytics (GA4 / GTM). ⚠️ NE PAS mapper AUSSI cet event vers la conversion
              // Ads ci-dessous dans GTM : la conversion est déjà envoyée en direct → double-compte.
              if (window.dataLayer) window.dataLayer.push({
                event: 'lead_submitted',
                lead_id: leadId,
                projet: payload.type_demande || '',
                prix_estime: v3,
                currency: 'EUR',
              });
              // ── Conversion Google Ads « formulaire devis » — DIRECTE ──────────────────
              // Tirée ici (et nulle part ailleurs) au succès confirmé de l'enregistrement.
              // Consent Mode v2 gère le consentement / la modélisation cookieless ; identique
              // à la conversion « appel ». transaction_id = clé de déduplication côté Google.
              // Routage de la conversion selon le type de demande : « DPE seul » (low-ticket)
              // → action « Soloris - Devis DPE » ; tout le reste (vente/location/audit) →
              // « Soloris - Devis Vente ». Le Smart Bidding distingue ainsi le CA réel.
              var isDpe = (payload.type_demande === 'dpe');
              var convSendTo = isDpe ? FORM_SEND_TO_DPE : FORM_SEND_TO;
              // Valeur = prix estimé réel (déjà bien plus élevé pour la Vente que pour un DPE) ;
              // fallback par type si l'estimation est indisponible (Vente 300 € / DPE 150 €).
              var convValue = v3 > 0 ? v3 : (isDpe ? 150 : 300);
              if (window.gtag && convSendTo) {
                // Enhanced Conversions : données fournies par l'utilisateur, posées AVANT
                // l'event de conversion (Google les hache côté client ; l'envoi reste soumis
                // au Consent Mode). Conversions améliorées pour les leads activées au niveau
                // compte (s'applique aux 2 actions Devis). Tél normalisé E.164.
                try {
                  var ecEmail = (val('email') || '').trim().toLowerCase();
                  var ecPhone = (val('telephone') || '').replace(/[^\d+]/g, '');
                  if (ecPhone && ecPhone.charAt(0) === '0') ecPhone = '+33' + ecPhone.slice(1);
                  var ecData = {};
                  if (ecEmail) ecData.email = ecEmail;
                  if (ecPhone) ecData.phone_number = ecPhone;
                  if (ecEmail || ecPhone) window.gtag('set', 'user_data', ecData);
                } catch (e2) {}
                window.gtag('event', 'conversion', {
                  send_to: convSendTo,
                  value: convValue,
                  currency: 'EUR',
                  transaction_id: leadId || undefined,
                });
              }
            }
            // Meta (plateforme DISTINCTE de Google → aucun double-compte). Inactif
            // aujourd'hui ; conservé pour quand le pixel Meta sera réactivé.
            if (window.fbq) window.fbq('track', 'Lead');
          } catch (err) {}
          // Estimation CONDITIONNÉE AU CONTACT : on ne dévoile le montant qu'ICI, une fois
          // les coordonnées envoyées (évite que le trafic froid prenne le prix puis reparte).
          var estEl = document.getElementById('qthanks-estim');
          if (estEl && REVEAL_ESTIMATION) {
            var estv = Number(payload.estimation || 0);
            estEl.innerHTML = estv > 0
              ? 'Votre estimation : <strong>à partir de ' + fmtEUR(estv) + '</strong> tout compris, déplacement inclus. Devis exact confirmé lors du rappel.'
              : 'Votre devis personnalisé vous est confirmé lors du rappel, tout compris et sans engagement.';
            estEl.hidden = false;
          }
          form.hidden = true;
          document.getElementById('qthanks').hidden = false;
          document.getElementById('qform').scrollIntoView({ behavior: 'smooth', block: 'start' });
        })
        .catch(function () {
          submitted = false; btn.disabled = false; btn.textContent = 'Obtenir mon devis';
          var nav = steps[steps.length - 1].querySelector('.qnav');
          if (!steps[steps.length - 1].querySelector('.qerror')) {
            var err = document.createElement('p'); err.className = 'qerror';
            err.textContent = "Une erreur est survenue. Réessayez ou appelez-nous directement.";
            nav.parentNode.insertBefore(err, nav);
          }
        });
    });

    // ── A/B test de l'ordre/nombre d'étapes : A = 5 étapes ; B = « type de bien »
    //    fusionné dans l'étape surface (4 étapes perçues). Repli sûr sur A si erreur. ──
    (function abSteps() {
      var v;
      if (LOCK_EXPERIMENTS) {
        // LP : baseline forcée FORCE_STEPS, AUCUN cookie lu/posé, AUCUNE impression 'steps_order'.
        v = (FORCE_STEPS === 'B') ? 'B' : 'A';
      } else {
        var name = 'soloris_ab_steps';
        v = (document.cookie.split('; ').find(function (c) { return c.indexOf(name + '=') === 0; }) || '').split('=')[1];
        if (v !== 'A' && v !== 'B') {
          v = Math.random() < 0.5 ? 'A' : 'B';
          var dt = new Date(); dt.setTime(dt.getTime() + 90 * 864e5);
          document.cookie = name + '=' + v + '; expires=' + dt.toUTCString() + '; path=/; SameSite=Lax';
        }
        try { if (window.dataLayer) window.dataLayer.push({ event: 'experiment_impression', experiment: 'steps_order', variant: v }); } catch (e) {}
      }
      if (v !== 'B') return;
      try {
        var s2 = form.querySelector('.qstep[data-step="2"]');
        var s3 = form.querySelector('.qstep[data-step="3"]');
        var bienGrid = s2 && s2.querySelector('.qgrid');
        if (!s2 || !s3 || !bienGrid) return; // repli sur A
        var wrap = document.createElement('div'); wrap.className = 'qfield-group';
        var lab = document.createElement('span'); lab.className = 'qgroup-label'; lab.textContent = 'Type de bien';
        wrap.appendChild(lab); wrap.appendChild(bienGrid);
        s3.insertBefore(wrap, s3.querySelector('.qfield')); // avant la surface
        s2.parentNode.removeChild(s2);
        steps = Array.prototype.slice.call(form.querySelectorAll('.qstep'));
        if (dots[4]) dots[4].style.display = 'none'; // 4 étapes
        abStepsB = true; // le sous-titre (avec/sans âge) est géré par updateEstimation
      } catch (e) { /* repli silencieux sur le parcours A */ }
    })();

    applyAutoSteps();
    showStep(0);
  })();
</script>
