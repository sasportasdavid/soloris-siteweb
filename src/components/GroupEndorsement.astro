---
/**
 * Mention de groupe « Une marque du groupe ISDIAG » (charte : classe .endorse).
 * Sora 500 · 11px · letter-spacing .14em · uppercase · trait séparateur · ISDIAG en gras.
 * variant : 'light' (fond clair) | 'dark' (fond bleu). Mention SECONDAIRE :
 * toujours plus petite et moins contrastée que le wordmark. Aucune couleur en dur
 * (uniquement des tokens de design).
 */
interface Props {
  variant?: 'light' | 'dark';
  compact?: boolean; // version réduite/discrète (ex. sous le logo du header)
  class?: string;
}
const { variant = 'light', compact = false, class: cls = '' } = Astro.props;
---
<span class={`endorse ${variant === 'dark' ? 'on-dark' : ''} ${compact ? 'sm' : ''} ${cls}`.replace(/\s+/g, ' ').trim()}>Une marque du groupe <b>ISDIAG</b></span>

<style>
  .endorse {
    font-family: var(--sora);
    font-weight: 500;
    font-size: 11px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--ink-soft);
    display: inline-flex;
    align-items: center;
    gap: 9px;
  }
  .endorse::before {
    content: "";
    width: 14px;
    height: 1px;
    background: var(--line);
    display: inline-block;
  }
  .endorse b { font-weight: 600; color: var(--blue-light); letter-spacing: .1em; }
  .endorse.on-dark { color: var(--ink-on-dark); }
  .endorse.on-dark::before { background: var(--rule-on-dark); }
  .endorse.on-dark b { color: var(--ink-on-dark-strong); }

  /* Version compacte/discrète (sous le logo du header) */
  .endorse.sm { font-size: 8.5px; letter-spacing: .09em; gap: 6px; opacity: .85; }
  .endorse.sm::before { width: 9px; }
  .endorse.sm b { letter-spacing: .06em; }
</style>
