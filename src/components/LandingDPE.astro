---
/**
 * Landing page « parcours DPE » nav-strippée, dédiée à la campagne Ads DPE
 * (avant : ces annonces tombaient sur la page d'offre générique /dpe, avec
 * pleine navigation + prix à l'écran).
 *
 * Stratégie « tarif par email » : AUCUN prix affiché. Le prix est calculé en
 * coulisse par le tunnel (revealEstimation=false) et poussé dans lead_submitted ;
 * le visiteur reçoit son tarif au rappel / par email. Symétrie de structure avec
 * LandingVente (bras B) : hero + formulaire de rappel, douleur, inclus, 4 piliers
 * (zéro prix), aperçu de rapport, process 48 h, preuve sociale, tunnel, FAQ.
 */
import LandingLayout from '../layouts/LandingLayout.astro';
import ReassuranceBar from './ReassuranceBar.astro';
import ReportPreview from './ReportPreview.astro';
import Reviews from './Reviews.astro';
import ReviewWall from './ReviewWall.astro';
import Faq from './Faq.astro';
import QuoteForm from './QuoteForm.astro';
import { getOffer } from '../lib/offers';
import { SITE } from '../lib/site';

const recallSla = '48 h';
const offer = getOffer('dpe')!;
const hasReviews = Number(SITE.rating.count) > 0;

// Métadonnées SANS prix (cohérent avec la stratégie tarif-par-email).
const title = 'DPE à Paris & Île-de-France — certifié, sous 48 h | Soloris';
const description =
  'Votre DPE par un diagnostiqueur certifié COFRAC, rapport opposable et clair sous 48 h à Paris et en Île-de-France. Devis personnalisé en 2 min.';
const path = '/lp/dpe';

// 4 piliers (équivalent de la grille tarifaire du bras vente A) — AUCUN prix.
const piliers = [
  { t: 'Rapidité', d: 'Rendez-vous et rapport sous 48 h dans la plupart des cas.', p: 'M12 7v5l3 3M12 3a9 9 0 100 18 9 9 0 000-18z' },
  { t: 'Conformité', d: 'DPE réglementaire, méthode 3CL, opposable — valable 10 ans.', p: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z' },
  { t: 'Clarté', d: 'Un rapport pédagogique : vous comprenez votre étiquette, sans jargon.', p: 'M5 13l4 4L19 7' },
  { t: 'Conseil énergie', d: 'On vous explique vos pistes d’amélioration, sans promesse de résultat.', p: 'M13 2L3 14h7l-1 8 10-12h-7l1-8z' },
];

// FAQ propre à la LP : on réutilise le contenu réel de l'offre DPE, MAIS on remplace
// la réponse « prix » (qui affiche un montant) par une réponse « tarif par email ».
const faqDpe = [
  offer.faq[0], // « Combien de temps est valable un DPE ? »
  {
    q: 'Comment connaître le prix de mon DPE ?',
    a: 'Renseignez votre bien en 2 minutes : vous recevez votre tarif tout compris, déplacement inclus, par email — sans engagement. Le prix dépend de la surface du logement.',
  },
  offer.faq[2], // « Pouvez-vous me garantir une bonne étiquette ? »
  offer.faq[3], // « Intervenez-vous rapidement ? »
];
---
<LandingLayout title={title} description={description} path={path}>
  <!-- Bandeau d'info slim — NON cliquable (préserve le nav-strip) -->
  <div class="lp-strip">
    <div class="wrap">Certifié COFRAC · Paris &amp; Île-de-France · Rapport opposable sous 48 h</div>
  </div>

  <!-- Héro 2 colonnes : accroche + CTA (gauche) · formulaire de rappel (droite) -->
  <section class="lp-hero">
    <svg class="lp-hero-sun" viewBox="0 0 100 100" fill="none" aria-hidden="true">
      <circle cx="50" cy="50" r="30" stroke="#2E6FAE" stroke-width="1.4" opacity="0.45" />
      <circle cx="50" cy="50" r="40" stroke="#2E6FAE" stroke-width="1.4" opacity="0.28" />
      <circle cx="50" cy="50" r="49.3" stroke="#2E6FAE" stroke-width="1.4" opacity="0.16" />
      <path d="M 79.9 36.1 A 33 33 0 1 1 63.9 20.1" stroke="#FFC94D" stroke-width="5" stroke-linecap="round" />
      <path d="M 52 48 L 94 6" stroke="#F5A623" stroke-width="5" stroke-linecap="round" />
    </svg>
    <div class="wrap lp-hero-grid">
      <div class="lp-hero-copy">
        <span class="tagpill">
          <svg width="14" height="14" viewBox="0 0 100 100" fill="none" aria-hidden="true"><path d="M 53 47 L 84 16" stroke="#F5A623" stroke-width="12" stroke-linecap="round" /><path d="M 79.9 36.1 A 33 33 0 1 1 63.9 20.1" stroke="#2E6FAE" stroke-width="12" stroke-linecap="round" /></svg>
          Certifié COFRAC · Rapport opposable
        </span>
        <h1>Votre DPE à Paris &amp; Île-de-France, certifié et opposable — sous 48 h.</h1>
        <p class="lp-sub">Un diagnostiqueur certifié COFRAC chez vous rapidement, un rapport clair qui explique votre étiquette énergie — sans jargon, conseil inclus.</p>
        {hasReviews && (
          <div class="lp-rating" aria-label={`Note ${SITE.rating.value} sur 5, ${SITE.rating.count} avis Google`}>
            <span class="stars" aria-hidden="true">
              {[0,1,2,3,4].map(() => <svg width="16" height="16" viewBox="0 0 24 24" fill="#F5A623"><path d="M12 2l2.9 6.2 6.8.8-5 4.7 1.3 6.7L12 17.8 5.9 20.4 7.2 13.7l-5-4.7 6.8-.8z"/></svg>)}
            </span>
            <strong>{SITE.rating.value}</strong> · {SITE.rating.count} avis Google
          </div>
        )}
        <div class="lp-cta"><a href="#simulateur" class="btn-gold">Obtenir mon devis en 2 min</a></div>
        <div class="lp-trust">
          <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2E6FAE" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg> Devis gratuit, sans engagement</span>
          <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2E6FAE" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg> Tarif tout compris, zéro frais surprise</span>
          <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2E6FAE" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg> Rapport opposable sous 48 h</span>
          <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2E6FAE" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg> Certifié COFRAC</span>
        </div>
      </div>
      <div class="lp-hero-visual">
        <QuoteForm
          lockExperiments={true}
          forceCta="A"
          forceSteps="A"
          revealEstimation={false}
          defaultDemande="dpe"
          recallSla={recallSla}
        />
      </div>
    </div>
  </section>

  <!-- Réassurance (note · avis · COFRAC · Assuré) -->
  <ReassuranceBar />

  <!-- Section douleur (PAS : Problem → Agitate → Solve) -->
  <section class="section-line">
    <div class="wrap" style="max-width:820px">
      <div class="eyebrow">Le problème</div>
      <h2 class="sec-title">Un DPE, vite et bien fait</h2>
      <p class="sec-intro">Besoin d'un DPE pour vendre, louer ou y voir clair sur votre logement ? Entre les délais, les diagnostiqueurs injoignables et les rapports incompréhensibles, ça traîne — alors que votre projet, lui, n'attend pas.</p>
      <p class="sec-intro mt-3">Soloris intervient rapidement à Paris et en Île-de-France et vous remet un DPE <b>certifié COFRAC</b>, <b>opposable</b> et <b>lisible</b> — sous 48 h, tarif tout compris annoncé d'avance, sans frais surprise.</p>
    </div>
  </section>

  <!-- Ce qui est inclus -->
  <section class="section-line">
    <div class="wrap">
      <div class="eyebrow">Ce qui est inclus</div>
      <h2 class="sec-title">Le contenu de votre DPE</h2>
      <p class="sec-intro">Une intervention complète sur place et un rapport clair, conforme et opposable.</p>
      <ul class="incl grid grid-2 mt-5">
        {offer.inclus.map((it) => (
          <li>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
            <span><b>{it.label}</b><br /><span class="muted" style="font-size:14px" set:html={it.detail} /></span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- 4 piliers — SANS aucun prix (équivalent de la grille tarifaire) -->
  <section class="section-line">
    <div class="wrap">
      <div class="eyebrow">Pourquoi Soloris</div>
      <h2 class="sec-title">Le bon diagnostic, simplement</h2>
      <p class="sec-intro">Un devis personnalisé, un rendez-vous rapide, un rapport clair et opposable — sans engagement.</p>
      <div class="grid grid-2 mt-5 lp-pillars">
        {piliers.map((p) => (
          <div class="card lp-pillar">
            <span class="lp-pillar-ic" aria-hidden="true"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d={p.p} /></svg></span>
            <h3>{p.t}</h3>
            <p>{p.d}</p>
          </div>
        ))}
      </div>
      <p class="price-note">Devis personnalisé tout compris, confirmé lors de votre rappel sous {recallSla}. Déplacement inclus, sans engagement.</p>
    </div>
  </section>

  <!-- Aperçu de rapport (un vrai aperçu de rapport DPE) -->
  <section class="section-line" id="rapport-type">
    <div class="wrap">
      <div class="sec-head center">
        <div class="eyebrow center">À quoi ressemble un rapport</div>
        <h2 class="sec-title">Un rapport clair, opposable</h2>
        <p class="sec-intro">Lisible au premier coup d'œil, conçu pour vous comme pour votre notaire ou votre locataire. (Exemple illustratif.)</p>
      </div>
      <div class="mt-5" style="max-width:880px;margin-left:auto;margin-right:auto"><ReportPreview /></div>
    </div>
  </section>

  <!-- Process 48 h -->
  <section class="section-line">
    <div class="wrap">
      <div class="eyebrow">Notre process</div>
      <h2 class="sec-title">De la demande au rapport, sous 48&nbsp;h</h2>
      <div class="grid grid-3 mt-5 steps">
        <div class="step"><div class="n">Étape 1</div><h3>Devis en 2 minutes</h3><p>Renseignez votre bien en ligne, en quelques clics.</p></div>
        <div class="step"><div class="n">Étape 2</div><h3>Rendez-vous sous 48 h</h3><p>Un diagnostiqueur certifié intervient rapidement.</p></div>
        <div class="step"><div class="n">Étape 3</div><h3>Rapport pédagogique</h3><p>Document clair et opposable, livré rapidement.</p></div>
      </div>
    </div>
  </section>

  <!-- Preuve sociale -->
  <Reviews limit={3} title="Ils nous ont fait confiance" eyebrow="Avis vérifiés" />

  <!-- Tunnel de devis (mode verrouillé, SANS prix affiché, pré-réglé sur DPE) -->
  <section class="section-line">
    <div class="wrap">
      <div class="sec-head center">
        <div class="eyebrow center">Devis en 2 min</div>
        <h2 class="sec-title">Obtenez votre devis</h2>
      </div>
      <div class="mt-5" id="simulateur">
        <QuoteForm
          lockExperiments={true}
          forceCta="A"
          forceSteps="A"
          revealEstimation={false}
          defaultDemande="dpe"
          recallSla={recallSla}
        />
      </div>
    </div>
  </section>

  <!-- FAQ / objections (sans prix) -->
  <Faq items={faqDpe} title="Vos questions sur le DPE" eyebrow="FAQ" />

  <!-- Wall of love -->
  <ReviewWall />

  <!-- CTA final -->
  <section class="cta-final">
    <div class="wrap">
      <h2>Votre DPE, en toute clarté</h2>
      <p>Devis en 2 minutes, rendez-vous sous 48 h, sans engagement.</p>
      <div class="cta"><a href="#simulateur" class="btn-gold">Obtenir mon devis en 2 min</a></div>
    </div>
  </section>
</LandingLayout>

<style>
  .lp-strip { background: var(--blue); color: #fff; }
  .lp-strip .wrap { text-align: center; font-family: var(--sora); font-weight: 500; font-size: 12.5px; letter-spacing: .01em; padding: 9px 0; }
  .lp-hero { position: relative; overflow: hidden; padding: 52px 0 40px; background: linear-gradient(180deg, var(--paper), #fff); }
  .lp-hero-sun { position: absolute; top: -90px; right: -120px; width: 460px; height: 460px; opacity: .5; pointer-events: none; }
  .lp-hero-grid { position: relative; display: grid; grid-template-columns: 1.05fr .95fr; gap: 48px; align-items: center; }
  .lp-hero-copy .tagpill { display: inline-flex; align-items: center; gap: 7px; font-family: var(--sora); font-weight: 600; font-size: 12.5px; color: var(--blue-light); background: rgba(46,111,174,.09); border-radius: 999px; padding: 6px 14px; margin-bottom: 18px; }
  .lp-hero-copy h1 { font-family: var(--sora); font-weight: 600; font-size: clamp(28px, 3.4vw, 42px); color: var(--blue); letter-spacing: -.01em; line-height: 1.12; }
  .lp-sub { font-size: 18px; color: var(--ink-soft); margin-top: 14px; max-width: 520px; line-height: 1.5; }
  .lp-rating { display: flex; align-items: center; gap: 8px; margin-top: 18px; font-family: var(--sora); font-size: 13.5px; color: var(--ink-soft); }
  .lp-rating .stars { display: inline-flex; gap: 1px; }
  .lp-rating strong { color: var(--blue); }
  .lp-cta { margin-top: 24px; }
  .lp-trust { display: flex; flex-wrap: wrap; gap: 8px 18px; margin-top: 22px; font-family: var(--sora); font-weight: 500; font-size: 13px; color: var(--blue-light); }
  .lp-trust span { display: inline-flex; align-items: center; gap: 7px; }
  .lp-hero-visual { position: relative; }
  .lp-pillars { gap: 16px; }
  .lp-pillar { padding: 24px 26px; }
  .lp-pillar-ic { display: inline-flex; align-items: center; justify-content: center; width: 44px; height: 44px; border-radius: 12px; background: rgba(245,166,35,.12); margin-bottom: 14px; }
  .lp-pillar h3 { font-family: var(--sora); font-weight: 600; font-size: 17px; color: var(--blue); }
  .lp-pillar p { font-size: 14.5px; color: var(--ink-soft); margin-top: 6px; line-height: 1.5; }
  .price-note { margin-top: 22px; font-size: 13.5px; color: var(--ink-soft); font-style: italic; }
  @media (max-width: 820px) {
    .lp-hero-grid { grid-template-columns: 1fr; gap: 30px; }
    .lp-hero-visual { max-width: 460px; }
  }
</style>
