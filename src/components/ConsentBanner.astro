---
/**
 * Bandeau de consentement conforme CNIL :
 * - Refuser aussi simple qu'accepter (2 boutons de même niveau).
 * - Choix granulaire (Mesure d'audience / Publicité), rien de pré-coché.
 * - Met à jour le Consent Mode v2 via window.solorisApplyConsent().
 * Le Meta Pixel ne se charge qu'après consentement publicité (géré dans Analytics).
 */
---
<div id="consent-banner" class="consent" role="dialog" aria-modal="false" aria-label="Gestion du consentement aux cookies" hidden>
  <div class="consent-inner">
    <div class="consent-text">
      <p>
        <b>Aidez-nous à améliorer Soloris.</b> Avec votre accord, nous analysons la navigation
        pour simplifier le site et mieux vous accompagner (statistiques détaillées, mesure de nos campagnes).
        Une mesure d'audience anonyme, sans cookie, est déjà active. <a href="/confidentialite">En savoir plus</a>.
      </p>

      <div id="consent-options" class="consent-options" hidden>
        <label class="consent-opt">
          <input type="checkbox" id="opt-analytics" />
          <span><b>Mesure d'audience</b> — statistiques de visites (Google Analytics).</span>
        </label>
        <label class="consent-opt">
          <input type="checkbox" id="opt-ads" />
          <span><b>Publicité</b> — mesure de nos campagnes (Google Ads, Meta).</span>
        </label>
        <label class="consent-opt">
          <input type="checkbox" id="opt-behavior" />
          <span><b>Analyse de navigation</b> — comprendre votre parcours pour améliorer le site (statistiques internes, enregistrement de session anonymisé, sans aucune donnée tierce).</span>
        </label>
      </div>
    </div>

    <div class="consent-actions">
      <button type="button" class="btn-ghost btn-sm" id="consent-refuse">Tout refuser</button>
      <button type="button" class="btn-ghost btn-sm" id="consent-custom">Personnaliser</button>
      <button type="button" class="btn-gold btn-sm" id="consent-accept">Tout accepter</button>
      <button type="button" class="btn-blue btn-sm" id="consent-save" hidden>Enregistrer mes choix</button>
    </div>
  </div>
</div>

<!-- Bouton flottant pour rouvrir les préférences (obligation CNIL : retrait facile) -->
<button type="button" id="consent-reopen" class="consent-reopen" aria-label="Gérer les cookies" hidden>
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="9"/><path d="M12 8v4M12 16h.01"/></svg>
</button>

<style>
  /* Barre fine en bas — ne recouvre pas le CTA/formulaire */
  .consent {
    position: fixed; left: 0; right: 0; bottom: 0; z-index: 1000;
    background: #fff; backdrop-filter: saturate(180%) blur(8px);
    border-top: 2px solid var(--gold); box-shadow: 0 -12px 40px -18px rgba(11, 42, 74, .45);
  }
  .consent-inner {
    max-width: var(--wrap); margin: 0 auto; padding: 12px 24px calc(12px + env(safe-area-inset-bottom));
    display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap;
  }
  .consent-text { flex: 1; min-width: 240px; }
  .consent-text p { font-size: 13px; color: var(--ink-soft); line-height: 1.5; }
  .consent-text a { color: var(--blue-light); text-decoration: underline; }
  .consent-options { margin-top: 10px; display: grid; gap: 8px; }
  .consent-opt { display: flex; gap: 10px; align-items: flex-start; font-size: 13px; color: var(--ink); cursor: pointer; }
  .consent-opt input { margin-top: 2px; width: 16px; height: 16px; accent-color: var(--blue-light); flex: none; }
  .consent-opt b { font-family: var(--sora); color: var(--blue); }
  .consent-actions { display: flex; flex-wrap: wrap; gap: 8px; flex: none; }
  .consent-reopen {
    position: fixed; left: 16px; bottom: 16px; z-index: 999;
    width: 42px; height: 42px; border-radius: 50%; border: 1px solid var(--line);
    background: #fff; color: var(--blue-light); cursor: pointer; box-shadow: var(--shadow-soft);
    display: flex; align-items: center; justify-content: center;
  }
  /* Sur mobile, on ne flotte pas le bouton au-dessus de la barre CTA (zone de conversion) :
     l'accès « Gérer les cookies » passe par le lien du footer (data-consent-open). */
  @media (max-width: 920px) { .consent-reopen { display: none; } }
  @media (max-width: 620px) {
    .consent-inner { padding: 10px 16px calc(10px + env(safe-area-inset-bottom)); }
    .consent-text p { font-size: 12.5px; }
    .consent-actions { width: 100%; }
    .consent-actions button { flex: 1; }
  }
</style>

<script is:inline>
  (function () {
    var banner = document.getElementById('consent-banner');
    var reopen = document.getElementById('consent-reopen');
    var options = document.getElementById('consent-options');
    var optAnalytics = document.getElementById('opt-analytics');
    var optAds = document.getElementById('opt-ads');
    var optBehavior = document.getElementById('opt-behavior');
    var btnAccept = document.getElementById('consent-accept');
    var btnRefuse = document.getElementById('consent-refuse');
    var btnCustom = document.getElementById('consent-custom');
    var btnSave = document.getElementById('consent-save');

    // `consent-pending` masque la barre CTA mobile tant que le choix n'est pas fait
    function show() { banner.hidden = false; reopen.hidden = true; document.body.classList.add('consent-pending'); }
    function hide() { banner.hidden = true; reopen.hidden = false; document.body.classList.remove('consent-pending'); }

    function stored() {
      try { return JSON.parse(localStorage.getItem('soloris_consent') || 'null'); } catch (e) { return null; }
    }

    function apply(consent) {
      if (window.solorisApplyConsent) window.solorisApplyConsent(consent); // gtag/Consent Mode (analytics/ads)
      // Tracker comportemental first-party (catégorie « behavior ») : démarre/arrête + purge au retrait.
      try { window.dispatchEvent(new CustomEvent('soloris-consent', { detail: consent })); } catch (e) {}
      hide();
    }

    // Affichage initial : bandeau si aucun choix mémorisé, sinon ré-applique
    var saved = stored();
    if (saved) { if (window.solorisApplyConsent) window.solorisApplyConsent(saved); reopen.hidden = false; }
    else { show(); }

    btnAccept.addEventListener('click', function () { apply({ analytics: true, ads: true, behavior: true }); });
    btnRefuse.addEventListener('click', function () { apply({ analytics: false, ads: false, behavior: false }); });
    btnCustom.addEventListener('click', function () {
      options.hidden = false; btnSave.hidden = false; btnCustom.hidden = true;
    });
    btnSave.addEventListener('click', function () {
      apply({ analytics: optAnalytics.checked, ads: optAds.checked, behavior: optBehavior.checked });
    });
    function openPrefs() {
      var s = stored();
      optAnalytics.checked = !!(s && s.analytics);
      optAds.checked = !!(s && s.ads);
      optBehavior.checked = !!(s && s.behavior);
      options.hidden = false; btnSave.hidden = false; btnCustom.hidden = true;
      show();
    }
    reopen.addEventListener('click', openPrefs);
    // Lien « Gérer les cookies » du footer (ou tout élément [data-consent-open])
    document.addEventListener('click', function (e) {
      var t = e.target.closest ? e.target.closest('[data-consent-open]') : null;
      if (t) { e.preventDefault(); openPrefs(); }
    });
  })();
</script>
