---
/**
 * Chat → Telegram (SENS UNIQUE, option A).
 * Bouton flottant → panneau (prénom, téléphone, message) → POST /api/lead avec
 * source="chat" → enregistrement Supabase + notification Telegram instantanée
 * (serveur, hors cookies). Fonctionne même en l'absence d'un conseiller : le
 * message devient un lead.
 * - Replié par défaut → ne recouvre jamais le CTA/formulaire au chargement.
 * - Positionné au-dessus de la barre CTA mobile ; masqué pendant le choix cookies.
 * RGPD : messages = données personnelles ; Telegram + Supabase sous-traitants
 * (cf. politique de confidentialité).
 */
---
<div class="chat" id="chat-widget">
  <button type="button" class="chat-fab" id="chat-fab" aria-expanded="false" aria-controls="chat-panel" aria-label="Ouvrir le chat">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
  </button>

  <div class="chat-panel" id="chat-panel" role="dialog" aria-label="Chat Soloris" hidden>
    <div class="chat-head">
      <div>
        <strong>Une question&nbsp;?</strong>
        <span>On vous répond vite.</span>
      </div>
      <button type="button" class="chat-x" id="chat-close" aria-label="Fermer le chat">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </div>

    <form id="chat-form" class="chat-body">
      <p class="chat-intro">Laissez-nous un message : on vous recontacte rapidement, même en dehors des horaires.</p>
      <input type="text" name="nom" required placeholder="Votre prénom" autocomplete="given-name" />
      <input type="tel" name="telephone" required placeholder="Votre téléphone" autocomplete="tel" />
      <textarea name="message" rows="3" required placeholder="Votre message…"></textarea>
      <div class="chat-hp" aria-hidden="true"><input type="text" name="website" tabindex="-1" autocomplete="off" /></div>
      <button type="submit" class="btn-gold btn-block" id="chat-send">Envoyer</button>
      <p class="chat-consent">En envoyant, vous acceptez d'être recontacté. <a href="/confidentialite">Confidentialité</a>.</p>
    </form>

    <div class="chat-thanks" id="chat-thanks" hidden>
      <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="#0B2A4A" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
      <strong>Message envoyé&nbsp;!</strong>
      <p>Merci, on vous répond très vite.</p>
    </div>
  </div>
</div>

<style>
  .chat-fab {
    position: fixed; right: 24px; bottom: 24px; z-index: 95;
    width: 56px; height: 56px; border-radius: 50%; border: none; cursor: pointer;
    background: var(--blue); color: #fff; box-shadow: 0 14px 30px -10px rgba(11,42,74,.6);
    display: flex; align-items: center; justify-content: center; transition: transform .12s ease, background .12s ease;
  }
  .chat-fab:hover { background: #0d3358; transform: translateY(-2px); }
  body.consent-pending .chat-fab { display: none; } /* pas pendant le choix cookies */

  .chat-panel {
    position: fixed; right: 24px; bottom: 92px; z-index: 96; width: 340px; max-width: calc(100vw - 32px);
    background: #fff; border: 1px solid var(--line); border-radius: var(--radius-lg); box-shadow: var(--shadow-strong); overflow: hidden;
  }
  .chat-head { background: var(--blue); color: #fff; padding: 16px 18px; display: flex; align-items: center; justify-content: space-between; }
  .chat-head strong { font-family: var(--sora); font-weight: 600; font-size: 15px; display: block; }
  .chat-head span { font-size: 12.5px; color: #C3D2E2; }
  .chat-x { background: none; border: none; color: #9FB8D2; cursor: pointer; display: flex; padding: 2px; }
  .chat-x:hover { color: #fff; }
  .chat-body { padding: 16px 18px 18px; display: grid; gap: 10px; }
  .chat-intro { font-size: 13px; color: var(--ink-soft); line-height: 1.5; margin: 0; }
  .chat-body input, .chat-body textarea { width: 100%; border: 1.5px solid var(--line); border-radius: 10px; padding: 10px 12px; font-family: var(--inter); font-size: 14px; }
  .chat-body input:focus, .chat-body textarea:focus { outline: none; border-color: var(--blue-light); }
  .chat-consent { font-size: 11px; color: var(--ink-soft); margin: 2px 0 0; }
  .chat-consent a { color: var(--blue-light); text-decoration: underline; }
  .chat-hp { position: absolute; left: -9999px; height: 0; overflow: hidden; }
  .chat-thanks { padding: 26px 18px; text-align: center; }
  .chat-thanks strong { font-family: var(--sora); font-weight: 600; color: var(--blue); display: block; margin-top: 10px; }
  .chat-thanks p { font-size: 13.5px; color: var(--ink-soft); margin-top: 6px; }

  @media (max-width: 920px) {
    .chat-fab { bottom: 88px; right: 16px; } /* au-dessus de la barre CTA mobile */
    .chat-panel { bottom: 152px; right: 16px; }
  }
</style>

<script is:inline>
  (function () {
    var fab = document.getElementById('chat-fab');
    var panel = document.getElementById('chat-panel');
    var close = document.getElementById('chat-close');
    var form = document.getElementById('chat-form');
    if (!fab || !panel || !form) return;

    function open() { panel.hidden = false; fab.setAttribute('aria-expanded', 'true'); var f = panel.querySelector('input'); if (f) f.focus(); }
    function hide() { panel.hidden = true; fab.setAttribute('aria-expanded', 'false'); }
    fab.addEventListener('click', function () { panel.hidden ? open() : hide(); });
    close.addEventListener('click', hide);

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var send = document.getElementById('chat-send');
      var ok = true;
      ['nom', 'telephone', 'message'].forEach(function (n) {
        var el = form.querySelector('[name="' + n + '"]');
        var bad = !el.value.trim();
        el.style.borderColor = bad ? '#b3261e' : '';
        if (bad) ok = false;
      });
      if (!ok) return;
      send.disabled = true; send.textContent = 'Envoi…';

      var a = {};
      try { var raw = (document.cookie.split('; ').find(function (c) { return c.indexOf('soloris_acq=') === 0; }) || '').split('=')[1]; a = raw ? JSON.parse(decodeURIComponent(raw)) : {}; } catch (e) {}
      var payload = {
        source: 'chat', lead_status: 'complet',
        nom: form.nom.value, telephone: form.telephone.value, message: form.message.value,
        website: form.website.value,
        gclid: a.gclid || '', fbclid: a.fbclid || '',
        utm_source: a.utm_source || '', medium: a.utm_medium || '', campaign: a.utm_campaign || '',
        term: a.utm_term || '', content: a.utm_content || '',
        gads_keyword: a.keyword || '', gads_campaign_id: a.campaignid || '', gads_adgroup_id: a.adgroupid || '',
        gads_creative_id: a.creative || '', match_type: a.matchtype || '', device: a.device || '', network: a.network || '',
        landing_path: a.landing_path || window.location.pathname, referrer: a.referrer || '',
      };

      fetch('/api/lead', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) })
        .then(function (r) { return r.ok ? r.json() : Promise.reject(); })
        .then(function () {
          try { if (window.dataLayer) window.dataLayer.push({ event: 'soloris_chat' }); } catch (e) {}
          form.hidden = true;
          document.getElementById('chat-thanks').hidden = false;
        })
        .catch(function () {
          send.disabled = false; send.textContent = 'Envoyer';
          form.message.style.borderColor = '#b3261e';
          alert("Une erreur est survenue. Réessayez ou appelez-nous.");
        });
    });
  })();
</script>
