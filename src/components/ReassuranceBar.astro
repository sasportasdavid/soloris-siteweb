---
/**
 * Barre de réassurance (fond bleu) : 48 h · tout compris · COFRAC · note Google.
 * La note est issue de site.ts ([À REMPLACER par avis réels]).
 */
import { SITE } from '../lib/site';
const hasReviews = Number(SITE.rating.count) > 0;
---
<div class="reassurance">
  <div class="wrap">
    <div class="row">
      <span class="item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FFC94D" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
        Rapport sous 48 h
      </span>
      <span class="item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FFC94D" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
        Tarif tout compris
      </span>
      <span class="item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FFC94D" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Certifié COFRAC
      </span>
      <span class="item">
        <svg class="star" width="16" height="16" viewBox="0 0 24 24" fill="#FFC94D" aria-hidden="true"><path d="M12 2l2.9 6.2 6.8.8-5 4.7 1.3 6.7L12 17.8 5.9 20.4 7.2 13.7l-5-4.7 6.8-.8z"/></svg>
        {hasReviews ? `${SITE.rating.value} sur Google (${SITE.rating.count} avis)` : 'Avis Google [À REMPLACER]'}
      </span>
    </div>
  </div>
</div>
