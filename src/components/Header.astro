---
/**
 * Header sticky : logo, navigation (menu Diagnostics déroulant), téléphone
 * cliquable et CTA or « Obtenir un devis ».
 */
import Logo from './Logo.astro';
import GroupEndorsement from './GroupEndorsement.astro';
import { SITE } from '../lib/site';
import { OFFERS } from '../lib/offers';
import { DIAGNOSTICS } from '../lib/diagnostics';

interface Props { hideCta?: boolean }
const { hideCta = false } = Astro.props;
const telHref = `tel:${SITE.phone.replace(/\s/g, '')}`;
---
<header class="site-header">
  <div class="wrap">
    <nav class="bar" aria-label="Navigation principale">
      <div class="brand-lockup">
        <a href="/" aria-label="Accueil Soloris"><Logo size={24} /></a>
        <GroupEndorsement variant="light" compact />
      </div>

      <button class="nav-toggle" id="nav-toggle" aria-expanded="false" aria-controls="primary-nav" aria-label="Ouvrir le menu">
        <svg class="ico-open" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
        <svg class="ico-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6 6 18"/></svg>
      </button>

      <div class="nav-links" id="primary-nav">
        <div class="has-menu">
          <button class="menu-btn" aria-haspopup="true" aria-expanded="false">
            Nos offres
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="menu-panel">
            {OFFERS.map((o) => (
              <a class="menu-item" href={o.url}>
                <b>{o.nav}</b>
                <span>{o.navDesc}</span>
              </a>
            ))}
          </div>
        </div>
        <div class="has-menu">
          <button class="menu-btn" aria-haspopup="true" aria-expanded="false">
            Les diagnostics
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="menu-panel">
            <a class="menu-item" href="/diagnostics">
              <b>Tous les diagnostics</b>
              <span>Le récapitulatif complet</span>
            </a>
            {DIAGNOSTICS.map((d) => (
              <a class="menu-item" href={d.ready ? `/diagnostics/${d.slug}` : '/diagnostics'}>
                <b>{d.nav}</b>
                <span>{d.priceLabel}</span>
              </a>
            ))}
          </div>
        </div>
        <a href="/tarifs">Tarifs</a>
        <a href="/methode">Méthode</a>
        <a href="/guides">Guides</a>
        <a href={telHref} class="nav-phone">{SITE.phoneDisplay}</a>
        {!hideCta && <a href="/devis" class="btn-gold btn-sm">Obtenir un devis</a>}
      </div>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    var toggle = document.getElementById('nav-toggle');
    var nav = document.getElementById('primary-nav');
    if (!toggle || !nav) return;
    var mq = window.matchMedia('(max-width: 920px)');

    function closeAccordions() {
      nav.querySelectorAll('.has-menu.open').forEach(function (m) {
        m.classList.remove('open');
        var b = m.querySelector('.menu-btn');
        if (b) b.setAttribute('aria-expanded', 'false');
      });
    }
    function closeMenu() {
      nav.classList.remove('open');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Ouvrir le menu');
      document.body.classList.remove('nav-open');
      closeAccordions();
    }
    function openMenu() {
      nav.classList.add('open');
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', 'Fermer le menu');
      document.body.classList.add('nav-open');
    }
    toggle.addEventListener('click', function () {
      if (nav.classList.contains('open')) closeMenu(); else openMenu();
    });

    // Accordéons « Nos offres » / « Les diagnostics » (mobile : le survol gère le desktop)
    nav.querySelectorAll('.has-menu .menu-btn').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        if (!mq.matches) return;
        e.preventDefault();
        var parent = btn.closest('.has-menu');
        var willOpen = !parent.classList.contains('open');
        closeAccordions(); // un seul panneau ouvert à la fois
        if (willOpen) { parent.classList.add('open'); btn.setAttribute('aria-expanded', 'true'); }
      });
    });

    // Fermer le menu après le clic sur un vrai lien de navigation
    nav.addEventListener('click', function (e) {
      var link = e.target.closest && e.target.closest('a[href]');
      if (link && nav.classList.contains('open')) closeMenu();
    });

    // Échap, clic en dehors, retour au desktop → on referme proprement
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeMenu(); });
    document.addEventListener('click', function (e) {
      if (!nav.classList.contains('open')) return;
      if (!nav.contains(e.target) && !toggle.contains(e.target)) closeMenu();
    });
    mq.addEventListener('change', function (e) { if (!e.matches) closeMenu(); });
  })();
</script>
