---
/**
 * Header sticky : logo, navigation (menu Diagnostics déroulant), téléphone
 * cliquable et CTA or « Obtenir un devis ».
 */
import Logo from './Logo.astro';
import { SITE } from '../lib/site';
import { OFFERS } from '../lib/offers';
import { DIAGNOSTICS } from '../lib/diagnostics';

interface Props { hideCta?: boolean }
const { hideCta = false } = Astro.props;
const telHref = `tel:${SITE.phone.replace(/\s/g, '')}`;
---
<header class="site-header">
  <div class="wrap">
    <nav class="bar" aria-label="Navigation principale">
      <a href="/" aria-label="Accueil Soloris">
        <Logo size={24} />
      </a>

      <button class="nav-toggle" id="nav-toggle" aria-expanded="false" aria-controls="primary-nav" aria-label="Ouvrir le menu">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#0B2A4A" stroke-width="2" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </button>

      <div class="nav-links" id="primary-nav">
        <div class="has-menu">
          <button class="menu-btn" aria-haspopup="true" aria-expanded="false">
            Diagnostics
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="menu-panel">
            {OFFERS.map((o) => (
              <a class="menu-item" href={o.url}>
                <b>{o.nav}</b>
                <span>{o.navDesc}</span>
              </a>
            ))}
          </div>
        </div>
        <div class="has-menu">
          <button class="menu-btn" aria-haspopup="true" aria-expanded="false">
            Les diagnostics
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="menu-panel">
            <a class="menu-item" href="/diagnostics">
              <b>Tous les diagnostics</b>
              <span>Le récapitulatif complet</span>
            </a>
            {DIAGNOSTICS.map((d) => (
              <a class="menu-item" href={d.ready ? `/diagnostics/${d.slug}` : '/diagnostics'}>
                <b>{d.nav}</b>
                <span>{d.priceLabel}</span>
              </a>
            ))}
          </div>
        </div>
        <a href="/tarifs">Tarifs</a>
        <a href="/methode">Méthode</a>
        <a href="/guides">Guides</a>
        <a href={telHref} class="nav-phone">{SITE.phoneDisplay}</a>
        {!hideCta && <a href="/devis" class="btn-gold btn-sm">Obtenir un devis</a>}
      </div>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    var toggle = document.getElementById('nav-toggle');
    var nav = document.getElementById('primary-nav');
    if (!toggle || !nav) return;
    toggle.addEventListener('click', function () {
      var open = nav.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(open));
    });
  })();
</script>
