---
/**
 * « Wall of love » : 2e bloc de preuve sociale (méthode Hormozi — afficher le
 * VOLUME, pas 3 avis). Bandeau agrégat (note Google réelle) + mur compact d'avis
 * réels supplémentaires (REVIEWS_EXTRA). N'affiche que du réel (source : reviews.ts).
 */
import { SITE } from '../lib/site';
import { REVIEWS_EXTRA } from '../lib/reviews';

interface Props {
  title?: string;
  eyebrow?: string;
  limit?: number;
}
const { title = 'Ils nous recommandent', eyebrow = 'Avis vérifiés', limit = 6 } = Astro.props;
const items = REVIEWS_EXTRA.slice(0, limit);
const hasReviews = Number(SITE.rating.count) > 0;
---
{hasReviews && (
  <section class="section-line">
    <div class="wrap">
      <div class="sec-head center">
        <div class="eyebrow center">{eyebrow}</div>
        <h2 class="sec-title">{title}</h2>
      </div>

      <!-- Bandeau agrégat : note Google réelle (volume de preuve) -->
      <div class="wall-agg mt-4">
        <span class="stars" aria-hidden="true">
          {[0,1,2,3,4].map(() => <svg width="18" height="18" viewBox="0 0 24 24" fill="#F5A623"><path d="M12 2l2.9 6.2 6.8.8-5 4.7 1.3 6.7L12 17.8 5.9 20.4 7.2 13.7l-5-4.7 6.8-.8z"/></svg>)}
        </span>
        <strong>{SITE.rating.value}/5</strong>
        <span class="agg-sub">· {SITE.rating.count} avis Google</span>
      </div>

      <!-- Mur d'avis compact -->
      <div class="wall-grid mt-5">
        {items.map((a) => (
          <div class="wall-card">
            <div class="stars" aria-label="5 étoiles sur 5">
              {[0,1,2,3,4].map(() => <svg width="14" height="14" viewBox="0 0 24 24" fill="#F5A623" aria-hidden="true"><path d="M12 2l2.9 6.2 6.8.8-5 4.7 1.3 6.7L12 17.8 5.9 20.4 7.2 13.7l-5-4.7 6.8-.8z"/></svg>)}
            </div>
            <p>« {a.txt} »</p>
            <div class="who">{a.who}<span>{a.sub}</span></div>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .wall-agg { display: flex; align-items: center; justify-content: center; gap: 10px; font-family: var(--sora); }
  .wall-agg .stars { display: inline-flex; gap: 2px; }
  .wall-agg strong { color: var(--blue); font-size: 18px; }
  .wall-agg .agg-sub { color: var(--ink-soft); font-size: 14px; }
  .wall-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .wall-card { background: #fff; border: 1px solid var(--line); border-radius: var(--radius); padding: 18px 20px; box-shadow: var(--shadow-card); }
  .wall-card .stars { display: inline-flex; gap: 1px; margin-bottom: 8px; }
  .wall-card p { font-size: 14px; color: var(--ink); line-height: 1.55; }
  .wall-card .who { margin-top: 12px; font-family: var(--sora); font-weight: 600; font-size: 13.5px; color: var(--blue); }
  .wall-card .who span { display: block; font-family: var(--inter); font-weight: 400; font-size: 12px; color: var(--ink-soft); margin-top: 2px; }
  @media (max-width: 820px) { .wall-grid { grid-template-columns: 1fr; } }
</style>
