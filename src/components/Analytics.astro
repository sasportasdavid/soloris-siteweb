---
/**
 * Tracking conforme RGPD/CNIL.
 * - Google Consent Mode v2 : tout en `denied` par défaut, défini AVANT toute balise.
 * - Google Tag Manager (GTM) : conteneur qui gère GA4 et les tags configurés
 *   dans l'interface GTM ; il respecte le Consent Mode défini ci-dessus.
 * - gtag (Google Ads) : conversions directes — soumission du formulaire (label
 *   formulaire) et clic sur un lien tel: (label « appel » distinct, PHONE_SEND_TO).
 * - Meta Pixel : chargé UNIQUEMENT après consentement publicité.
 * - Capture utm_* / gclid / fbclid → sessionStorage → champs cachés du formulaire.
 * GTM et gtag partagent le même dataLayer et le même état de consentement.
 */
const GTM = import.meta.env.PUBLIC_GTM_ID;
const GA4 = import.meta.env.PUBLIC_GA4_ID;
const GADS = import.meta.env.PUBLIC_GADS_ID;
const GADS_PHONE_LABEL = import.meta.env.PUBLIC_GADS_PHONE_LABEL;
const META = import.meta.env.PUBLIC_META_PIXEL_ID;

const PLACEHOLDER = '__A_REMPLACER__';
const hasGTM = !!GTM && GTM !== PLACEHOLDER;
const hasGtag = (!!GA4 && GA4 !== PLACEHOLDER) || (!!GADS && GADS !== PLACEHOLDER);
const hasMeta = !!META && META !== PLACEHOLDER;
// send_to dédié au clic téléphone (action de conversion distincte du formulaire)
const PHONE_SEND_TO =
  GADS && GADS !== PLACEHOLDER && GADS_PHONE_LABEL && GADS_PHONE_LABEL !== PLACEHOLDER
    ? `${GADS}/${GADS_PHONE_LABEL}`
    : '';
---

<!-- Bootstrap Consent Mode v2 — exécuté avant toute balise, tout en "denied" -->
<script is:inline define:vars={{ GA4, GADS, META, hasGtag, hasMeta, PHONE_SEND_TO }}>
  window.dataLayer = window.dataLayer || [];
  function gtag() { window.dataLayer.push(arguments); }
  window.gtag = gtag;

  // État de consentement par défaut : TOUT refusé (RGPD)
  gtag('consent', 'default', {
    ad_storage: 'denied',
    analytics_storage: 'denied',
    ad_user_data: 'denied',
    ad_personalization: 'denied',
    functionality_storage: 'granted',
    security_storage: 'granted',
    wait_for_update: 500,
  });
  gtag('js', new Date());
  if (GA4 && GA4 !== '__A_REMPLACER__') gtag('config', GA4, { anonymize_ip: true });
  if (GADS && GADS !== '__A_REMPLACER__') gtag('config', GADS);

  // ── Capture d'attribution publicitaire ─────────────────────────────
  (function captureAttribution() {
    try {
      var params = new URLSearchParams(window.location.search);
      var keys = ['utm_source','utm_medium','utm_campaign','utm_term','utm_content','gclid','fbclid'];
      var store = JSON.parse(sessionStorage.getItem('soloris_attribution') || '{}');
      var changed = false;
      keys.forEach(function (k) {
        var v = params.get(k);
        if (v) { store[k] = v; changed = true; }
      });
      if (!store.landing_path) { store.landing_path = window.location.pathname; changed = true; }
      if (changed) sessionStorage.setItem('soloris_attribution', JSON.stringify(store));
    } catch (e) { /* sessionStorage indisponible : on ignore */ }
  })();

  // ── Helpers de consentement (appelés par le bandeau CNIL) ───────────
  window.solorisLoadMetaPixel = function () {
    if (!META || META === '__A_REMPLACER__' || window.__metaLoaded) return;
    window.__metaLoaded = true;
    !(function (f, b, e, v, n, t, s) {
      if (f.fbq) return; n = f.fbq = function () { n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments); };
      if (!f._fbq) f._fbq = n; n.push = n; n.loaded = !0; n.version = '2.0'; n.queue = [];
      t = b.createElement(e); t.async = !0; t.src = v; s = b.getElementsByTagName(e)[0]; s.parentNode.insertBefore(t, s);
    })(window, document, 'script', 'https://connect.facebook.net/en_US/fbevents.js');
    window.fbq('init', META);
    window.fbq('track', 'PageView');
  };

  // Applique un consentement et déclenche les chargements conditionnels
  window.solorisApplyConsent = function (consent) {
    // consent = { analytics: bool, ads: bool }
    gtag('consent', 'update', {
      analytics_storage: consent.analytics ? 'granted' : 'denied',
      ad_storage: consent.ads ? 'granted' : 'denied',
      ad_user_data: consent.ads ? 'granted' : 'denied',
      ad_personalization: consent.ads ? 'granted' : 'denied',
    });
    if (consent.ads) window.solorisLoadMetaPixel();
    try { localStorage.setItem('soloris_consent', JSON.stringify(consent)); } catch (e) {}
  };

  // ── Conversion « Appel » : clic sur un lien tel: ────────────────────
  // Action de conversion Google Ads DISTINCTE du formulaire (label dédié).
  // gtag respecte le Consent Mode v2 : rien n'est envoyé tant que le
  // consentement publicité n'est pas accordé via le bandeau.
  document.addEventListener('click', function (e) {
    var link = e.target && e.target.closest ? e.target.closest('a[href^="tel:"]') : null;
    if (!link) return;
    try {
      if (window.gtag && PHONE_SEND_TO) {
        window.gtag('event', 'conversion', { send_to: PHONE_SEND_TO, value: 1.0, currency: 'EUR' });
      }
      if (window.dataLayer) window.dataLayer.push({ event: 'soloris_phone_call' });
    } catch (err) { /* on n'empêche jamais l'appel */ }
  }, true);
</script>

<!-- Google Tag Manager (après le Consent Mode : les tags GTM respectent le consentement) -->
{hasGTM && (
  <script is:inline define:vars={{ GTM }}>
    (function (w, d, s, l, i) {
      w[l] = w[l] || [];
      w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
      var f = d.getElementsByTagName(s)[0], j = d.createElement(s), dl = l != 'dataLayer' ? '&l=' + l : '';
      j.async = true; j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
      f.parentNode.insertBefore(j, f);
    })(window, document, 'script', 'dataLayer', GTM);
  </script>
)}

<!-- Librairie gtag pour Google Ads (conversion). Sous Consent Mode : aucun cookie tant que "denied". -->
{hasGtag && (
  <script
    type="text/partytown-ignore"
    is:inline
    async
    src={`https://www.googletagmanager.com/gtag/js?id=${GA4 && GA4 !== '__A_REMPLACER__' ? GA4 : GADS}`}
  ></script>
)}
