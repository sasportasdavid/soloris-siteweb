---
/**
 * Layout des LANDING PAGES Ads (nav-strippées) — utilisé UNIQUEMENT par les LP, donc
 * tout ce qui est ici est hérité À L'IDENTIQUE par les bras A et B du test 'price_model'
 * (aucun prix → compatible bras B).
 * - Même <head> que Base (SEO + Analytics/GTM + Consent Mode) pour conserver le tracking.
 * - PAS de navigation/menu/liens marketing : un seul but = convertir.
 * - Canaux de conversion (pas des sorties) : téléphone clic-to-call (bandeau + barre
 *   mobile collante) — la conversion « appel » est captée globalement par Analytics.astro.
 * - Footer de CONFIANCE : identité légale + COFRAC + zone + téléphone + liens légaux
 *   (mentions / confidentialité). Logo non cliquable. noindex par défaut.
 */
import '../styles/global.css';
import '@fontsource/sora/latin-300.css';
import '@fontsource/sora/latin-400.css';
import '@fontsource/sora/latin-500.css';
import '@fontsource/sora/latin-600.css';
import '@fontsource/sora/latin-700.css';
import '@fontsource/inter/latin-400.css';
import '@fontsource/inter/latin-500.css';
import '@fontsource/inter/latin-600.css';
import '@fontsource-variable/fraunces/wght.css';
import '@fontsource-variable/fraunces/wght-italic.css';
import soraH1Url from '@fontsource/sora/files/sora-latin-600-normal.woff2?url';

import Seo from '../components/Seo.astro';
import Analytics from '../components/Analytics.astro';
import ConsentBanner from '../components/ConsentBanner.astro';
import BehaviorTracking from '../components/BehaviorTracking.astro';
import Logo from '../components/Logo.astro';
import { SITE } from '../lib/site';

interface Props {
  title: string;
  description: string;
  path?: string;
  ogImage?: string;
  noindex?: boolean;
  jsonLd?: Record<string, any>[];
}
const { title, description, path, ogImage, noindex = true, jsonLd } = Astro.props;

const GTM = import.meta.env.PUBLIC_GTM_ID;
const hasGTM = !!GTM && GTM !== '__A_REMPLACER__';
const year = new Date().getFullYear();
const telHref = `tel:${SITE.phone.replace(/\s/g, '')}`;
const phoneSvg = 'M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.81.36 1.6.7 2.34a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.74-1.27a2 2 0 0 1 2.11-.45c.74.34 1.53.57 2.34.7A2 2 0 0 1 22 16.92z';
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#14385F" />
    <link rel="preload" href={soraH1Url} as="font" type="font/woff2" crossorigin />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
    <link rel="icon" href="/favicon-16.png" sizes="16x16" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <Seo title={title} description={description} path={path} ogImage={ogImage} noindex={noindex} jsonLd={jsonLd} />
    <Analytics />
  </head>
  <body>
    {hasGTM && (
      <noscript set:html={`<iframe src="https://www.googletagmanager.com/ns.html?id=${GTM}" height="0" width="0" style="display:none;visibility:hidden"></iframe>`} />
    )}
    <a href="#main" class="skip-link">Aller au contenu</a>

    <!-- En-tête minimal : logo NON cliquable + téléphone clic-to-call (canal de conversion) -->
    <header class="lp-head">
      <div class="wrap">
        <Logo />
        <a href={telHref} class="lp-head-phone" aria-label={`Appeler Soloris au ${SITE.phoneDisplay}`}>
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={phoneSvg} /></svg>
          <span>{SITE.phoneDisplay}</span>
        </a>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <!-- Footer de confiance (identité + COFRAC + zone + tél + légal). Aucun lien marketing. -->
    <footer class="lp-foot">
      <div class="wrap">
        <div class="lp-foot-top">
          <Logo />
          <p class="lp-foot-trust">{SITE.cofracNote} · {SITE.areaServed.join(' & ')} · <a href={telHref}>{SITE.phoneDisplay}</a></p>
        </div>
        <p class="lp-foot-id">{SITE.legalName}, {SITE.legalForm} — SIRET {SITE.siret} — exploitant la marque commerciale «&nbsp;{SITE.tradeName}&nbsp;».</p>
        <div class="lp-foot-legal">
          <span>© {year} {SITE.tradeName}</span>
          <span class="lp-foot-sep">·</span>
          <a href="/mentions-legales">Mentions légales</a>
          <span class="lp-foot-sep">·</span>
          <a href="/confidentialite">Confidentialité</a>
        </div>
      </div>
    </footer>

    <!-- Barre CTA collante (mobile) : 2 canaux de conversion, AUCUN lien de navigation -->
    <div class="lp-mcta" role="group" aria-label="Actions rapides">
      <a href="#simulateur" class="btn-gold lp-mcta-btn">Calculer mon prix</a>
      <a href={telHref} class="btn-blue lp-mcta-btn lp-mcta-call" aria-label={`Appeler le ${SITE.phoneDisplay}`}>
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={phoneSvg} /></svg>
        Appeler
      </a>
    </div>

    <ConsentBanner />
    <BehaviorTracking />

    <style>
      .lp-head { border-bottom: 1px solid var(--line); background: #fff; position: sticky; top: 0; z-index: 30; }
      .lp-head .wrap { display: flex; align-items: center; justify-content: space-between; gap: 12px; min-height: 62px; }
      .lp-head-phone { display: inline-flex; align-items: center; gap: 7px; font-family: var(--sora); font-weight: 600; font-size: 15px; color: var(--blue); text-decoration: none; }
      .lp-head-phone svg { color: var(--gold); }
      .lp-head-phone:hover { color: var(--blue-light); }

      .lp-foot { border-top: 1px solid var(--line); background: var(--paper); margin-top: 40px; }
      .lp-foot .wrap { padding: 26px 0 30px; }
      .lp-foot-top { display: flex; flex-wrap: wrap; align-items: center; gap: 10px 18px; }
      .lp-foot-trust { font-family: var(--sora); font-size: 13.5px; font-weight: 500; color: var(--ink-soft); }
      .lp-foot-trust a { color: var(--blue); text-decoration: none; }
      .lp-foot-id { font-size: 12.5px; color: var(--ink-soft); margin-top: 14px; line-height: 1.6; }
      .lp-foot-legal { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; margin-top: 12px; font-size: 13px; color: var(--ink-soft); }
      .lp-foot-legal a { color: var(--ink-soft); text-decoration: underline; }
      .lp-foot-legal a:hover { color: var(--blue); }
      .lp-foot-sep { opacity: .5; }

      /* Barre CTA collante — mobile uniquement */
      .lp-mcta { display: none; }
      @media (max-width: 820px) {
        .lp-mcta { display: flex; gap: 10px; position: fixed; left: 0; right: 0; bottom: 0; z-index: 40; padding: 10px 14px calc(10px + env(safe-area-inset-bottom)); background: rgba(255,255,255,.96); backdrop-filter: blur(8px); border-top: 1px solid var(--line); box-shadow: 0 -4px 16px -8px rgba(11,42,74,.25); }
        .lp-mcta-btn { flex: 1; text-align: center; }
        .lp-mcta-call { flex: 0 0 auto; display: inline-flex; align-items: center; justify-content: center; gap: 7px; }
        body { padding-bottom: 72px; } /* espace pour la barre fixe */
        .lp-head-phone span { display: none; } /* en-tête mobile : icône seule (la barre porte « Appeler ») */
      }
    </style>
  </body>
</html>
