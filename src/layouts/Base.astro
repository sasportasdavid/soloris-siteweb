---
/**
 * Layout de base du site public.
 * - Polices auto-hébergées (woff2) via @fontsource — PAS de CDN Google Fonts.
 * - Head SEO délégué au composant <Seo>.
 * - Tracking conforme (Consent Mode v2) + bandeau CNIL.
 */
import '../styles/global.css';
// Polices auto-hébergées (sous-ensemble latin pour Sora/Inter)
import '@fontsource/sora/latin-300.css';
import '@fontsource/sora/latin-400.css';
import '@fontsource/sora/latin-500.css';
import '@fontsource/sora/latin-600.css';
import '@fontsource/sora/latin-700.css';
import '@fontsource/inter/latin-400.css';
import '@fontsource/inter/latin-500.css';
import '@fontsource/inter/latin-600.css';
// Fraunces (variable) : roman + italique, pour la note éditoriale / baseline
import '@fontsource-variable/fraunces/wght.css';
import '@fontsource-variable/fraunces/wght-italic.css';

// Police du H1 (Sora 600) préchargée pour accélérer le LCP
import soraH1Url from '@fontsource/sora/files/sora-latin-600-normal.woff2?url';

import Seo from '../components/Seo.astro';
import Analytics from '../components/Analytics.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ConsentBanner from '../components/ConsentBanner.astro';
import MobileCtaBar from '../components/MobileCtaBar.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';
import ChatWidget from '../components/ChatWidget.astro';
import BehaviorTracking from '../components/BehaviorTracking.astro';

interface Props {
  title: string;
  description: string;
  path?: string;
  ogImage?: string;
  noindex?: boolean;
  jsonLd?: Record<string, any>[];
  hideHeaderCta?: boolean;
}
const { title, description, path, ogImage, noindex, jsonLd, hideHeaderCta } = Astro.props;

// Google Tag Manager — pour la balise <noscript> (repli sans JS)
const GTM = import.meta.env.PUBLIC_GTM_ID;
const hasGTM = !!GTM && GTM !== '__A_REMPLACER__';
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0B2A4A" />
    <link rel="preload" href={soraH1Url} as="font" type="font/woff2" crossorigin />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
    <link rel="icon" href="/favicon-16.png" sizes="16x16" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <Seo title={title} description={description} path={path} ogImage={ogImage} noindex={noindex} jsonLd={jsonLd} />
    <Analytics />
  </head>
  <body>
    {hasGTM && (
      <noscript set:html={`<iframe src="https://www.googletagmanager.com/ns.html?id=${GTM}" height="0" width="0" style="display:none;visibility:hidden"></iframe>`} />
    )}
    <a href="#main" class="skip-link">Aller au contenu</a>
    <AnnouncementBar />
    <Header hideCta={hideHeaderCta} />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <MobileCtaBar />
    <ChatWidget />
    <ConsentBanner />
    <BehaviorTracking />
  </body>
</html>
