---
/**
 * Accueil — hub + conversion. 13 sections (cf. brief §4).
 * Hero dynamique (landing DTR). JSON-LD : LocalBusiness + FAQPage.
 */
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import ReassuranceBar from '../components/ReassuranceBar.astro';
import OfferCard from '../components/OfferCard.astro';
import ReportPreview from '../components/ReportPreview.astro';
import EnergyScale from '../components/EnergyScale.astro';
import Reviews from '../components/Reviews.astro';
import ReviewWall from '../components/ReviewWall.astro';
import CallbackForm from '../components/CallbackForm.astro';
import QuoteForm from '../components/QuoteForm.astro';
import ResponsiveImage from '../components/ResponsiveImage.astro';
import Faq from '../components/Faq.astro';
import { OFFERS } from '../lib/offers';
import { prixDes } from '../lib/pricing';
import { SITE } from '../lib/site';
import { localBusiness, faqPage } from '../lib/jsonld';

const piliers = [
  { t: 'Clarté', d: 'Tarif tout compris affiché, rapport lisible sans jargon.', proof: 'Le prix que vous voyez est le prix final.', ic: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>' },
  { t: 'Rapidité', d: 'Rendez-vous et rapport sous 48 h dans la plupart des cas.', proof: 'Devis immédiat, intervention sous 48 h.', ic: '<path d="M13 2 3 14h7l-1 8 10-12h-7z"/>' },
  { t: 'Confiance', d: 'Diagnostiqueur certifié COFRAC, rapport opposable et assuré.', proof: 'Certifié COFRAC · rapport opposable.', ic: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>' },
  { t: 'Expertise énergie', d: "Conseil clair sur votre étiquette et les pistes d'amélioration.", proof: 'Un expert qui vous explique, sans vous vendre des travaux.', ic: '<circle cx="12" cy="12" r="4"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3"/>' },
];

const faq = [
  { q: 'Quels diagnostics sont obligatoires pour vendre ?', a: "Selon le bien : DPE, ERP, et selon l'âge et la zone — amiante, plomb (CREP), électricité, gaz, mesurage Loi Carrez, termites. Nous établissons la liste exacte applicable à votre logement au moment du devis." },
  { q: 'Quels diagnostics pour mettre en location ?', a: "Généralement le DPE et l'ERP, complétés selon le logement par le CREP (plomb), l'électricité, le gaz et le mesurage Loi Boutin. La composition est confirmée au devis." },
  { q: 'Combien de temps un DPE est-il valable ?', a: "Un DPE est valable 10 ans. Les DPE réalisés avant le 1ᵉʳ juillet 2021 ne sont toutefois plus valides depuis le 1ᵉʳ janvier 2025." },
  { q: 'Quels sont vos délais ?', a: 'Nous proposons un rendez-vous et la remise du rapport sous 48 h dans la plupart des cas à Paris et en Île-de-France.' },
  { q: 'Combien coûtent vos diagnostics ?', a: `Nos tarifs sont tout compris, déplacement inclus : dès ${prixDes('dpe')} € pour un DPE, dès ${prixDes('vente')} € pour un pack vente. Vous obtenez une estimation immédiate via notre formulaire de devis.` },
  { q: 'Dans quelle zone intervenez-vous ?', a: 'À Paris et dans toute l’Île-de-France.' },
  { q: 'Pouvez-vous garantir une bonne étiquette énergétique ?', a: "Non. Le DPE reflète la performance réelle du logement. Notre engagement porte sur la rigueur du diagnostic et la clarté du rapport — jamais sur le résultat." },
];

const jsonLd = [localBusiness(), faqPage(faq)];
const title = 'Diagnostics immobiliers Paris & Île-de-France | Soloris';
const description = 'DPE, vente, location et audit énergétique. Prix clair, diagnostiqueur certifié, rapport sous 48 h à Paris et en Île-de-France.';
---
<Base title={title} description={description} path="/" jsonLd={jsonLd}>
  <!-- 2 · Hero dynamique — simulateur de devis embarqué (composant unique QuoteForm) -->
  <Hero
    dynamic={true}
    h1='Diagnostics immobiliers à <span class="hl">Paris &amp; Île-de-France</span>'
    sub="DPE, vente, location ou audit énergétique : obtenez un prix clair, un rendez-vous rapide et un rapport sous 48 h."
    showTrust={true}
    sun={true}
    hideCta={true}
    aside={true}
  >
    <Fragment slot="aside">
      <QuoteForm revealEstimation={true} />
    </Fragment>
  </Hero>

  <!-- 3 · Barre de réassurance -->
  <ReassuranceBar />

  <!-- 3b · Capture express « Être rappelé » (téléphone + code postal, friction minimale) -->
  <section class="section-line" id="rappel">
    <div class="wrap">
      <div class="grid grid-2" style="align-items:center;gap:40px">
        <div>
          <div class="eyebrow">Pas envie de remplir un formulaire&nbsp;?</div>
          <h2 class="sec-title">Laissez votre numéro, on vous rappelle</h2>
          <p class="sec-intro">On vérifie avec vous les diagnostics obligatoires de votre bien, on confirme le prix tout compris et on fixe un rendez-vous sous 48&nbsp;h. Vous vendez, louez ou avez besoin d'un DPE&nbsp;: dites-le-nous.</p>
        </div>
        <CallbackForm title="Être rappelé rapidement" />
      </div>
    </div>
  </section>

  <!-- 4 · Quel est votre besoin ? -->
  <section class="section-line">
    <div class="wrap">
      <div class="sec-head center">
        <div class="eyebrow center">Par où commencer</div>
        <h2 class="sec-title">Quel est votre besoin&nbsp;?</h2>
        <p class="sec-intro">Choisissez votre situation : on vous emmène droit au bon diagnostic.</p>
      </div>
      <div class="grid grid-4 mt-5">
        {OFFERS.map((o) => <OfferCard offer={o} />)}
      </div>
    </div>
  </section>

  <!-- 5 · Comment ça marche -->
  <section class="section-line">
    <div class="wrap">
      <div class="eyebrow">Comment ça marche</div>
      <h2 class="sec-title">Trois étapes, zéro corvée</h2>
      <div class="grid grid-3 mt-5 steps">
        <div class="step">
          <div class="step-media step-media--price">
            <span class="step-n">Étape 1</span>
            <div class="step-price"><strong>Dès {prixDes('vente')} €</strong><span>tout compris</span></div>
          </div>
          <div class="step-body"><h3>Devis immédiat</h3><p>Renseignez votre bien en 2 minutes et obtenez une estimation tout compris à l'écran.</p></div>
        </div>
        <div class="step">
          <div class="step-media">
            <span class="step-n">Étape 2</span>
            <ResponsiveImage src="/images/mesure-tablette.webp" alt="Rendez-vous avec un diagnostiqueur certifié" width={520} height={358} />
          </div>
          <div class="step-body"><h3>Rendez-vous sous 48 h</h3><p>Un diagnostiqueur certifié intervient rapidement, à la date qui vous arrange.</p></div>
        </div>
        <div class="step">
          <div class="step-media">
            <span class="step-n">Étape 3</span>
            <ResponsiveImage src="/images/rapport-famille.webp" alt="Remise d'un rapport de diagnostic clair" width={520} height={358} />
          </div>
          <div class="step-body"><h3>Rapport pédagogique</h3><p>Vous recevez un rapport clair, opposable, qui vous dit où vous en êtes — sans jargon.</p></div>
        </div>
      </div>
    </div>
  </section>

  <!-- 6 · Nos engagements — 4 garanties (cartes numérotées 2×2) -->
  <section class="section-line">
    <div class="wrap">
      <div class="sec-head center">
        <div class="eyebrow center">Nos engagements</div>
        <h2 class="sec-title">Quatre garanties, aucune zone d'ombre</h2>
      </div>
      <div class="grid grid-2 mt-5 engage">
        {piliers.map((p, i) => (
          <div class="eng-card">
            <span class="eng-num" aria-hidden="true">{i + 1}</span>
            <div class="eng-body">
              <h3>{p.t}</h3>
              <p>{p.d}</p>
              <span class="eng-proof">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                {p.proof}
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 7 · Tarifs en aperçu -->
  <section class="section-line">
    <div class="wrap">
      <div class="block-blue">
        <div class="kicker">Tarifs tout compris</div>
        <h2>Dès {prixDes('vente')} € tout compris, déplacement inclus</h2>
        <p>Pas de frais cachés, pas de surprise. Le prix que vous voyez au devis est le prix que vous payez. Nos tarifs sont justes — jamais le luxe, jamais l'à-peu-près.</p>
        <div class="flex-cta mt-3">
          <a href="/tarifs" class="btn-gold">Voir tous les tarifs</a>
          <a href="/devis" class="btn-ghost" style="color:#fff;border-color:rgba(255,255,255,.3)">Obtenir mon devis</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 8 · Expertise énergie / réforme DPE -->
  <section class="section-line">
    <div class="wrap">
      <div class="split-media">
        <div class="split-media-img">
          <ResponsiveImage src="/images/camera-thermique.webp" alt="Diagnostiqueuse réalisant un relevé à la caméra thermique" width={620} height={720} sizes="(max-width: 760px) 92vw, 620px" />
        </div>
        <div class="split-media-body">
          <div class="eyebrow">Expertise énergie</div>
          <h2 class="sec-title">Comprendre votre étiquette, anticiper la réforme</h2>
          <p class="sec-intro">
            Le DPE et l'audit énergétique prennent une place croissante dans la vie d'un logement.
            Chez Soloris, un expert vous explique votre étiquette et les pistes d'amélioration —
            clairement, sans vous vendre de travaux.
          </p>
          <p class="muted mt-2" style="font-size:14.5px">
            La loi Climat et résilience interdit progressivement la location des logements énergivores
            (classe G depuis 2025, F en 2028, E en 2034) et un audit énergétique est requis à la vente
            des logements F, G et E. Au 1ᵉʳ janvier 2026, le calcul du DPE évolue aussi (coefficient de
            l'électricité). Nous faisons le point sur votre situation au moment du devis.
          </p>
          <div class="escale-compact mt-3">
            <EnergyScale highlight="C" />
          </div>
          <div class="flex-cta mt-3">
            <a href="/audit-energetique" class="btn-blue">L'audit énergétique</a>
            <a href="/guides/reforme-dpe" class="btn-ghost">Réforme DPE : ce qui change</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 9 · Aperçu d'un rapport type -->
  <section class="section-line" id="rapport-type">
    <div class="wrap">
      <div class="sec-head center">
        <div class="eyebrow center">À quoi ressemble un rapport</div>
        <h2 class="sec-title">Un rapport clair, opposable</h2>
        <p class="sec-intro">Lisible au premier coup d'œil, conçu pour votre notaire comme pour vous. (Exemple illustratif.)</p>
      </div>
      <div class="mt-5" style="max-width:880px;margin-left:auto;margin-right:auto">
        <ReportPreview />
      </div>
    </div>
  </section>

  <!-- 10 · Avis clients -->
  <Reviews limit={3} title="Ce que disent nos clients" eyebrow="Ils nous ont fait confiance" />

  <!-- 10b · Wall of love — 2e bloc de preuve sociale (volume d'avis réels) -->
  <ReviewWall />

  <!-- 10c · Bandeau terrain Paris & Île-de-France -->
  <section class="geo-band">
    <div class="wrap">
      <div class="eyebrow center">Notre terrain</div>
      <h2>À Paris et dans toute l'Île-de-France</h2>
      <p>Nos diagnostiqueurs certifiés COFRAC interviennent à Paris et dans toute l'Île-de-France, avec un rendez-vous et un rapport sous 48 h dans la plupart des cas.</p>
      <a href="/devis" class="btn-gold">Obtenir mon devis</a>
    </div>
  </section>

  <!-- 11 · FAQ -->
  <Faq items={faq} title="Vos questions, nos réponses claires" />

  <!-- 12 · CTA final -->
  <section class="cta-final cta-final--split">
    <div class="wrap cta-final-grid">
      <div class="cta-final-copy">
        <h2>Prêt à y voir clair&nbsp;?</h2>
        <p>Obtenez votre estimation tout compris en 2 minutes. Sans engagement.</p>
        <div class="cta">
          <a href="/devis" class="btn-gold">Obtenir mon devis en 2 min</a>
          <a href={`tel:${SITE.phone.replace(/\s/g, '')}`} class="btn-ghost" style="color:#fff;border-color:rgba(255,255,255,.3)">Nous appeler</a>
        </div>
      </div>
      <div class="cta-final-media">
        <ResponsiveImage src="/images/remise-cles.webp" alt="Remise des clés d'un appartement" width={640} height={520} sizes="(max-width: 760px) 92vw, 640px" />
      </div>
    </div>
  </section>
</Base>

<style>
  /* Nos engagements — cartes numérotées 2×2 (registre institutionnel) */
  .engage { gap: 22px; }
  .eng-card {
    display: flex; gap: 18px;
    background: #fff; border: 1px solid var(--line); border-radius: 10px; padding: 28px;
    transition: border-color .15s ease, box-shadow .15s ease, transform .15s ease;
  }
  .eng-card:hover { border-color: var(--line-strong); box-shadow: var(--shadow-card); transform: translateY(-2px); }
  .eng-num {
    flex: none; width: 44px; height: 44px; border-radius: 10px;
    background: var(--blue); color: var(--amber);
    font-family: var(--serif); font-style: italic; font-weight: 400; font-size: 23px;
    display: flex; align-items: center; justify-content: center; line-height: 1;
  }
  .eng-body h3 { font-family: var(--sora); font-weight: 600; font-size: 19px; color: var(--blue); margin-bottom: 6px; }
  .eng-body p { font-size: 14.5px; color: var(--ink-soft); }
  .eng-proof {
    display: inline-flex; align-items: center; gap: 8px; margin-top: 13px;
    font-family: var(--sora); font-weight: 600; font-size: 13px; color: var(--gold-hover);
  }
  .eng-proof svg { flex: none; color: var(--green); }
  @media (max-width: 720px) { .eng-card { padding: 22px; } }
</style>
