---
/**
 * /rdv/<token> — formulaire public de confirmation de RDV, ouvert depuis Telegram
 * (bouton « Caler le RDV » → lien signé expirant). Valide le token côté serveur,
 * affiche LE MÊME formulaire que le back-office (source unique rdvForm), pré-rempli.
 * Inopérant si lien invalide/expiré ou RDV déjà confirmé.
 */
export const prerender = false;

import '../../styles/global.css';
import { verifyRdvToken } from '../../lib/rdvToken';
import { rdvPrefill, renderRdvFormFields, RDV_FORM_CSS } from '../../lib/rdvForm';
import { SUPABASE_URL, SUPABASE_ANON } from '../../lib/serverEnv';
import { SITE } from '../../lib/site';

const token = String(Astro.params.token || '');
const payload = verifyRdvToken(token);

let state: 'invalid' | 'confirmed' | 'form' = 'invalid';
let lead: any = null;

if (payload && SUPABASE_URL && SUPABASE_ANON) {
  try {
    const res = await fetch(`${SUPABASE_URL}/rest/v1/rpc/get_lead_for_rdv`, {
      method: 'POST',
      headers: { apikey: SUPABASE_ANON, Authorization: `Bearer ${SUPABASE_ANON}`, 'Content-Type': 'application/json' },
      body: JSON.stringify({ p_id: payload.lead_id }),
    });
    if (res.ok) {
      const j = await res.json();
      if (j?.found) {
        if (j.already_confirmed) state = 'confirmed';
        else { state = 'form'; lead = j.lead; }
      }
    }
  } catch { /* state reste invalid */ }
}

const formHtml = lead ? renderRdvFormFields(rdvPrefill(lead)) : '';
const telHref = `tel:${SITE.phone.replace(/\s/g, '')}`;
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Confirmer le rendez-vous — Soloris</title>
  <style is:global set:html={RDV_FORM_CSS}></style>
  <style>
    body { background: var(--paper); }
    .rdv-wrap { max-width: 560px; margin: 0 auto; padding: 24px 18px 60px; }
    .rdv-head { display: flex; align-items: center; gap: 10px; padding: 18px 0 24px; }
    .rdv-head .mark { font-family: var(--sora); font-weight: 600; font-size: 22px; color: var(--blue); letter-spacing: -.02em; }
    .rdv-head .bl { font-size: 12px; color: var(--ink-soft); }
    .rdv-card { background: #fff; border: 1px solid var(--line); border-top: 3px solid var(--gold); border-radius: 16px; box-shadow: var(--shadow-card); padding: 24px 22px 26px; }
    .rdv-card h1 { font-family: var(--sora); font-weight: 600; font-size: 22px; color: var(--blue); margin-bottom: 8px; }
    .rdv-card p { color: var(--ink-soft); font-size: 14.5px; line-height: 1.6; margin-bottom: 16px; }
    .rdv-actions { margin-top: 20px; }
    #rdv-submit { width: 100%; }
    #rdv-pub-msg { font-size: 13px; margin-top: 12px; min-height: 16px; }
    #rdv-pub-msg.err { color: #b3261e; }
    .rdv-foot { text-align: center; font-size: 12px; color: var(--ink-soft); margin-top: 20px; }
    .rdv-foot a { color: var(--blue-light); }
  </style>
</head>
<body>
  <div class="rdv-wrap">
    <div class="rdv-head">
      <span class="mark">soloris</span>
      <span class="bl">· Le diagnostic, en toute clarté.</span>
    </div>

    {state === 'form' && (
      <div class="rdv-card" id="rdv-card">
        <h1>Confirmez le rendez-vous</h1>
        <p>Vérifiez les informations, ajustez si besoin, puis envoyez la confirmation au client (email + invitation agenda).</p>
        <form id="rdv-public" onsubmit="return false">
          <Fragment set:html={formHtml} />
          <div class="rdv-actions">
            <button type="button" class="btn-gold btn-block" id="rdv-submit">Confirmer &amp; envoyer la confirmation</button>
            <p id="rdv-pub-msg"></p>
          </div>
        </form>
      </div>
    )}

    {state === 'confirmed' && (
      <div class="rdv-card">
        <h1>Rendez-vous déjà confirmé</h1>
        <p>Ce rendez-vous a déjà fait l'objet d'une confirmation. Aucune action supplémentaire n'est nécessaire.</p>
      </div>
    )}

    {state === 'invalid' && (
      <div class="rdv-card">
        <h1>Lien expiré ou invalide</h1>
        <p>Ce lien de confirmation n'est plus valide (expiré ou déjà utilisé). Rapprochez-vous de l'équipe Soloris pour en générer un nouveau.</p>
        <a class="btn-blue" href={telHref}>Appeler l'équipe — {SITE.phoneDisplay}</a>
      </div>
    )}

    <p class="rdv-foot">soloris.fr · Paris &amp; Île-de-France · Une marque du groupe ISDIAG</p>
  </div>

  {state === 'form' && (
    <script is:inline define:vars={{ token }}>
      (function () {
        var btn = document.getElementById('rdv-submit');
        var msg = document.getElementById('rdv-pub-msg');
        function v(id) { var e = document.getElementById(id); return e ? e.value.trim() : ''; }
        btn.addEventListener('click', async function () {
          var date = v('rdv-date'), time = v('rdv-time');
          if (!date || !time) { msg.textContent = "Indiquez la date et l'heure."; msg.className = 'err'; return; }
          var when = new Date(date + 'T' + time);
          if (isNaN(when.getTime())) { msg.textContent = 'Date ou heure invalide.'; msg.className = 'err'; return; }
          var old = btn.textContent; btn.disabled = true; btn.textContent = 'Envoi…'; msg.textContent = ''; msg.className = '';
          try {
            var r = await fetch('/api/rdv/confirm-public', {
              method: 'POST', headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                token: token, rdv_at: when.toISOString(),
                rdv_adresse: v('rdv-adresse'), prestation: v('rdv-prestation'), diagnostiqueur: v('rdv-diag'),
                prix_total_ttc: Number(v('rdv-prix')) || 0, duree_estimee: v('rdv-duree'), consignes: v('rdv-consignes'),
              }),
            });
            var j = await r.json();
            if (!r.ok || !j.ok) { msg.textContent = (j && j.error) || 'Une erreur est survenue.'; msg.className = 'err'; btn.disabled = false; btn.textContent = old; return; }
            document.getElementById('rdv-card').innerHTML =
              '<h1>Rendez-vous confirmé.</h1><p>La confirmation a bien été envoyée au client' + (j.emailSent ? ' par email' : '') + '. Vous pouvez fermer cette page.</p>';
          } catch (e) {
            msg.textContent = 'Connexion impossible, réessayez.'; msg.className = 'err'; btn.disabled = false; btn.textContent = old;
          }
        });
      })();
    </script>
  )}
</body>
</html>
