---
/**
 * /tarifs — pilier Clarté. Grille complète + add-ons. JSON-LD AggregateOffer + FAQ.
 */
import Base from '../layouts/Base.astro';
import PricingTable from '../components/PricingTable.astro';
import ReassuranceBar from '../components/ReassuranceBar.astro';
import Reviews from '../components/Reviews.astro';
import Faq from '../components/Faq.astro';
import { ADDONS, APPART_GRID, MAISON_SUPP, MAISON_COPRO_SUPPLEMENT, DPE_FROM, DPE_TO, AUDIT_FROM, LOT_ANNEXE_PRICE } from '../lib/pricing';
import { SITE } from '../lib/site';
import { faqPage, breadcrumb } from '../lib/jsonld';

// Bornes de prix du site (pack appart/maison + DPE + audit) pour l'AggregateOffer
const packNums = APPART_GRID.filter(Boolean).flatMap((r) => r as readonly number[]);
const siteLow = Math.min(DPE_FROM, ...packNums);
const siteHigh = Math.max(AUDIT_FROM, Math.max(...packNums) + MAISON_SUPP);

const aggregateOffer = {
  '@context': 'https://schema.org',
  '@type': 'AggregateOffer',
  priceCurrency: 'EUR',
  lowPrice: String(siteLow),
  highPrice: String(siteHigh),
  availability: 'https://schema.org/InStock',
  areaServed: SITE.areaServed.map((name) => ({ '@type': 'AdministrativeArea', name })),
};

const faq = [
  { q: 'Pourquoi le prix dépend-il de l\'âge du bien ?', a: "Parce que les diagnostics obligatoires varient selon la date de construction : amiante et plomb sont requis sur les biens anciens, pas sur les plus récents. Un bien d'avant 1949 nécessite donc plus de diagnostics qu'un logement de moins de 15 ans." },
  { q: 'Le déplacement est-il inclus dans le prix ?', a: 'Oui. Tous nos tarifs sont tout compris, déplacement inclus à Paris et en Île-de-France. Aucun frais caché.' },
  { q: 'Comment est calculé le prix d\'une maison ?', a: `Le prix d'une maison correspond à celui d'un appartement de même surface et même âge, majoré de ${MAISON_SUPP} €. Pour une maison en copropriété, comptez ${MAISON_COPRO_SUPPLEMENT} € de plus.` },
  { q: 'Comment obtenir un prix ferme ?', a: 'Utilisez notre formulaire de devis : vous indiquez la surface et l\'âge du bien, vous obtenez une estimation immédiate, puis un devis confirmé sans engagement.' },
];

const jsonLd = [aggregateOffer, faqPage(faq), breadcrumb([{ name: 'Accueil', url: '/' }, { name: 'Tarifs', url: '/tarifs' }])];
---
<Base
  title="Tarifs des diagnostics immobiliers, tout compris | Soloris"
  description="Tarifs tout compris des diagnostics immobiliers à Paris et Île-de-France : DPE, vente, location, audit. Déplacement inclus, sans frais cachés."
  path="/tarifs"
  jsonLd={jsonLd}
>
  <div class="wrap">
    <nav class="breadcrumb" aria-label="Fil d'Ariane"><a href="/">Accueil</a> <span>/</span> <span aria-current="page">Tarifs</span></nav>
  </div>

  <section>
    <div class="wrap">
      <div class="eyebrow">Tarifs</div>
      <h1 class="sec-title" style="font-size:44px">Tarifs tout compris, déplacement inclus</h1>
      <p class="sec-intro">Le prix que vous voyez est le prix que vous payez. Jamais le luxe, jamais l'à-peu-près : un tarif juste, et la transparence en prime.</p>
    </div>
  </section>

  <ReassuranceBar />

  <section class="section-line">
    <div class="wrap">
      <div class="eyebrow">Pack vente & location</div>
      <h2 class="sec-title" style="font-size:28px">Le prix selon la surface et l'âge du bien</h2>
      <p class="sec-intro">Le tarif dépend de l'âge du logement, car les diagnostics obligatoires changent : amiante et plomb sont requis sur les biens anciens, pas sur les plus récents.</p>
      <div class="mt-5"><PricingTable caption="Grille tarifaire Soloris" /></div>
    </div>
  </section>

  <section class="section-line">
    <div class="wrap">
      <div class="eyebrow">Prestations énergie</div>
      <h2 class="sec-title">DPE seul & audit énergétique</h2>
      <div class="grid grid-2 mt-5">
        <div class="card" style="padding:26px 28px">
          <h3 style="font-family:var(--sora);font-weight:600;font-size:19px;color:var(--blue)">DPE seul</h3>
          <p style="font-family:var(--sora);font-weight:600;font-size:26px;color:var(--blue);margin:8px 0 4px">dès {DPE_FROM} €</p>
          <p class="muted" style="font-size:14px">{DPE_FROM} à {DPE_TO} € selon la surface, tout compris, déplacement inclus.</p>
          <p class="mt-2"><a href="/dpe" class="btn-ghost btn-sm">L'offre DPE</a></p>
        </div>
        <div class="card" style="padding:26px 28px">
          <h3 style="font-family:var(--sora);font-weight:600;font-size:19px;color:var(--blue)">Audit énergétique</h3>
          <p style="font-family:var(--sora);font-weight:600;font-size:26px;color:var(--blue);margin:8px 0 4px">dès {AUDIT_FROM} €</p>
          <p class="muted" style="font-size:14px">Pour les logements énergivores (F, G, E), tout compris, selon le bien.</p>
          <p class="mt-2"><a href="/audit-energetique" class="btn-ghost btn-sm">L'audit énergétique</a></p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-line">
    <div class="wrap">
      <div class="eyebrow">À la carte</div>
      <h2 class="sec-title">Diagnostics complémentaires</h2>
      <p class="sec-intro">Certains diagnostics s'ajoutent selon votre bien. Voici les principaux, à titre indicatif.</p>
      <div style="overflow-x:auto" class="mt-5">
        <table class="ptable">
          <thead><tr><th scope="col">Diagnostic</th><th scope="col">Tarif indicatif</th></tr></thead>
          <tbody>
            {ADDONS.map((a) => (
              <tr>
                <th scope="row" style="font-weight:500">{a.label}</th>
                <td class="price">{a.prefix}{a.price} €{a.note ? <small> · {a.note}</small> : null}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="price-note">Montants TTC indicatifs. La liste exacte applicable à votre bien est confirmée au devis.</p>

      <div style="margin-top:18px;background:var(--paper);border:1px solid var(--line);border-left:3px solid var(--gold);border-radius:12px;padding:16px 20px">
        <strong style="font-family:var(--sora);color:var(--blue)">Cave, parking ou box vendu seul</strong>
        <span class="price"> — {LOT_ANNEXE_PRICE} € tout compris</span>
        <span style="display:block;font-size:13.5px;margin-top:4px;color:var(--ink-soft)">Tarif unique pour ces lots, déplacement inclus.</span>
      </div>
    </div>
  </section>

  <Reviews limit={3} title="Ils nous ont fait confiance" eyebrow="Avis vérifiés" />

  <section class="cta-final">
    <div class="wrap">
      <h2>Une estimation en 2 minutes</h2>
      <p>Obtenez votre prix tout compris immédiatement, sans engagement.</p>
      <div class="cta"><a href="/devis" class="btn-gold">Obtenir mon devis</a></div>
    </div>
  </section>

  <Faq items={faq} title="Questions sur nos tarifs" />
</Base>
