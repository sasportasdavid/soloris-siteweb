---
/**
 * Gabarit d'une page diagnostic : /diagnostics/{slug}
 * Génère uniquement les diagnostics `ready` (phase de validation).
 * JSON-LD : Service + FAQPage + BreadcrumbList. Maillage vers les packs + /devis.
 * Conforme : factuel, aucune promesse de résultat, prix = grille.
 */
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import ReassuranceBar from '../../components/ReassuranceBar.astro';
import Faq from '../../components/Faq.astro';
import { DIAGNOSTICS, type Diagnostic } from '../../lib/diagnostics';
import { getOffer } from '../../lib/offers';
import { service, faqPage, breadcrumb } from '../../lib/jsonld';
import { prixDes } from '../../lib/pricing';

export function getStaticPaths() {
  return DIAGNOSTICS.filter((d) => d.ready).map((d) => ({ params: { diag: d.slug }, props: { diag: d } }));
}

interface Props { diag: Diagnostic }
const { diag } = Astro.props;
const url = `/diagnostics/${diag.slug}`;

const packLinks = diag.inPack.map((p) => getOffer(p === 'vente' ? 'diagnostics-vente' : 'diagnostics-location')!);

const jsonLd = [
  service({ name: diag.name, description: diag.metaDesc, url, priceFrom: prixDes('dpe') }),
  faqPage(diag.faq),
  breadcrumb([
    { name: 'Accueil', url: '/' },
    { name: 'Tous les diagnostics', url: '/diagnostics' },
    { name: diag.name, url },
  ]),
];
---
<Base title={diag.title} description={diag.metaDesc} path={url} jsonLd={jsonLd}>
  <div class="wrap">
    <nav class="breadcrumb" aria-label="Fil d'Ariane">
      <a href="/">Accueil</a> <span>/</span> <a href="/diagnostics">Tous les diagnostics</a> <span>/</span> <span aria-current="page">{diag.name}</span>
    </nav>
  </div>

  <Hero
    tagpill="Certifié COFRAC · Rapport opposable"
    h1={`${diag.h1}, <span class="hl">en toute clarté</span>`}
    sub={diag.tagline}
    primaryHref="/devis"
    primaryLabel="Obtenir mon devis en 2 min"
    secondaryHref="#tarif"
    secondaryLabel="Voir le tarif"
    showTrust={true}
    sun={true}
  />

  <ReassuranceBar />

  <!-- Ce que c'est + quand c'est obligatoire (2 colonnes) -->
  <section class="section-line">
    <div class="wrap">
      <div class="grid grid-2" style="align-items:start;gap:44px">
        <div>
          <div class="eyebrow">En quoi consiste ce diagnostic</div>
          <h2 class="sec-title" style="font-size:30px">{diag.name}</h2>
          <p class="sec-intro" style="font-size:18px;color:var(--ink);max-width:none">{diag.intro}</p>
        </div>
        <div class="card" style="padding:28px">
          <div class="eyebrow">Quand est-ce requis&nbsp;?</div>
          <ul class="incl mt-3" style="gap:12px">
            {diag.when.map((w) => (
              <li>
                <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                <span set:html={w} />
              </li>
            ))}
          </ul>
          <p class="muted mt-3" style="font-size:13px">Nous confirmons si ce diagnostic s’applique à votre bien au moment du devis, selon la réglementation en vigueur.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Tarif + inclusion pack -->
  <section class="section-line" id="tarif">
    <div class="wrap" style="max-width:820px">
      <div class="eyebrow">Tarif</div>
      <h2 class="sec-title">Combien ça coûte&nbsp;?</h2>
      <p class="sec-intro" style="font-size:19px;color:var(--ink)"><strong style="font-family:var(--sora);color:var(--blue)">{diag.priceLabel}</strong>, tout compris, déplacement inclus.</p>
      {diag.inPack.length > 0 && (
        <p class="sec-intro mt-2">Ce diagnostic est inclus dans {diag.inPack.map((p, i) => (
          <span>{i > 0 ? ' et ' : ''}<a href={p === 'vente' ? '/diagnostics-vente' : '/diagnostics-location'}>{p === 'vente' ? 'le pack vente' : 'le pack location'}</a></span>
        ))} — regrouper vos diagnostics revient à un tarif plus avantageux qu’à l’unité.</p>
      )}
      <div class="flex-cta mt-4">
        <a href="/devis" class="btn-blue">Obtenir mon devis en 2 min</a>
        <a href="/tarifs" class="btn-ghost">Voir tous les tarifs</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <Faq items={diag.faq} title="Questions fréquentes" eyebrow="FAQ" />

  <!-- Maillage -->
  <section class="section-line">
    <div class="wrap">
      <div class="eyebrow">Aller plus loin</div>
      <h2 class="sec-title">Vos diagnostics, en un seul rendez-vous</h2>
      <div class="grid grid-3 mt-5">
        {packLinks.map((o) => (
          <a class="need-card" href={o.url}>
            <h3>{o.nav}</h3>
            <p>{o.navDesc}.</p>
            <span class="go">Dès {prixDes(o.demande)} € tout compris
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
          </a>
        ))}
        <a class="need-card" href="/diagnostics">
          <h3>Tous les diagnostics</h3>
          <p>Le détail de chaque diagnostic.</p>
          <span class="go">Voir le récapitulatif
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="cta-final">
    <div class="wrap">
      <h2>{diag.name}, en toute clarté</h2>
      <p>Estimation tout compris en 2 minutes, sans engagement.</p>
      <div class="cta"><a href="/devis" class="btn-gold">Obtenir mon devis</a></div>
    </div>
  </section>
</Base>
